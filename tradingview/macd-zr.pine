//@version=6
// @description 2Ai MACD ZR — oscillateur MACD "zero-lag" paramétrable DEMA / TEMA / ZLEMA.
//              Portage de la version v5 de référence (`_tv-indicators/macd-zr.pine`, DEMA-only)
//              avec ajout du choix de méthode de lissage. Toute la logique de calcul vit dans
//              `lib_macd.zeroLag()` ; l'indicateur n'orchestre que les inputs et le rendu.
indicator(title = "2Ai MACD ZR", shorttitle = "MACD ZR", overlay = false)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_ma/3   as ma
import mpilard/lib_macd/1 as macd

// ============================================================
// Inputs
// ============================================================
src          = input.source(close,        "Source")
fastLength   = input.int(12,              "Fast length",   minval = 1)
slowLength   = input.int(26,              "Slow length",   minval = 1)
signalLength = input.int(9,               "Signal length", minval = 1)
maMode       = input.enum(ma.MaMode.DEMA, "Méthode de lissage", tooltip = "DEMA : lisse, lag réduit (parité avec la version v5 de référence). TEMA : compromis lag/lissage poussé. ZLEMA : très réactif, plus bruité.")

// ============================================================
// Calculs — délégués à lib_macd
// ============================================================
[macdLine, signalLine, hist, average] = macd.zeroLag(src, fastLength, slowLength, signalLength, maMode)

// ============================================================
// Rendu — orchestration de plots (Pine impose plot() en top-level)
// ============================================================
mainColor = hist > 0 ? color.rgb(76, 175, 79) : color.rgb(255, 82, 82)

plot(hist, title = "Histogram", style = plot.style_columns, color = mainColor)

pSignal = plot(signalLine, title = "Signal",  color = mainColor,  linewidth = 1)
pMacd   = plot(macdLine,   title = "MACD ZR", color = color.gray)
fill(pMacd, pSignal, title = "MACD Background", color = hist > 0 ? color.rgb(76, 175, 79, 50) : color.rgb(255, 82, 82, 75))

plot(average, title = "MA Line", color = color.rgb(82, 122, 255))
