//@version=6
// 2Ai_Strat_OR — Stratégie Open Range (première heure du jour).
// Deux setups sur le range OR :
//   - CASSURE       : une bougie clôture hors du range (continuation).
//   - RÉINTÉGRATION : une bougie sort (mèche ou N clôtures) puis clôture dans le range (fade).
// ENTRÉE = ordre STOP sur l'extrême de la bougie déclencheuse, dans le sens du trade :
//   long → buy-stop sur son HAUT ; short → sell-stop sur son BAS. L'ordre reste valide jusqu'à ce que
//   le setup soit invalidé (le prix atteint le niveau du SL avant l'entrée) ou la fin de journée.
//   Garde-fou : si l'extrême a déjà dépassé le TP1, le setup est ignoré.
// SL/TP multi-cibles paramétrables, BE au TP1, runner. Sizing par risque constant (perte au SL = %
// d'equity fixé). Rendu : 1 box position (entrée→TP3) + lignes TP1/TP2 + 1 box SL (grisée au BE/sortie).
// Un rayon au niveau d'entrée (vert long / rouge short) porte la taille restante (live) ; au TP3 la box se fige, le rayon continue.
// Panneau debug (haut-droite) : compteurs réels (setups / placés / skips / annulés / filés / engine).
// Spec : .docs/SPECIFICATIONS.md § "Stratégie 1 : 2Ai_Strat_OR".
//
// Contrainte plateforme : une stratégie Pine n'a qu'UNE position nette. Un setup de sens opposé à
// la position en cours est SKIPPÉ (sinon strategy.entry inverserait la position). Pyramiding = même sens.
strategy("2Ai_Strat_OR", shorttitle = "Strat OR", overlay = true,
  pyramiding = 100,                                     // borne haute ; le vrai plafond/jour est `tradesMax`
  default_qty_type = strategy.percent_of_equity,
  default_qty_value = 1.0,                              // fallback ; écrasé par la qty explicite (sizing par risque)
  initial_capital = 10000,
  calc_on_every_tick = false,
  process_orders_on_close = true,                       // entrée au marché à la CLÔTURE de la bougie-flèche
  max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

import mpilard/lib_levels/12 as levels

// ============================================================
// Inputs
// ============================================================
var string GRP_GEN = "Général"
orTz      = input.string("Europe/Paris", "TZ Open Range",     group = GRP_GEN, tooltip = "TZ IANA définissant le 'minuit' de l'Open Range (Pine n'expose pas la TZ du chart).")
tradesMax = input.int(3,                 "Trades max / jour",  group = GRP_GEN, minval = 1,    maxval = 10)
maxOpen   = input.int(2,                 "Positions max en cours", group = GRP_GEN, minval = 1, maxval = 10, tooltip = "Positions ouvertes simultanément autorisées (renfort). Au-delà, le setup est ignoré.")
// Sens / hedge (const strings : options input.string + comparaisons)
DIR_BOTH  = "Les deux sens (hedge)"
DIR_LONG  = "Long seul"
DIR_SHORT = "Short seul"
DIR_NET   = "Sens unique (net, anti-hedge)"
dirMode   = input.string(DIR_BOTH, "Sens / hedge", options = [DIR_BOTH, DIR_LONG, DIR_SHORT, DIR_NET], group = GRP_GEN, tooltip = "Les deux sens (hedge) : on DESSINE les deux ; ⚠ le moteur n'a qu'une position nette (il nette les sens opposés) → backtest fiable surtout en Long/Short/Net. Long/Short seul : un seul sens. Sens unique (net) : refuse un setup opposé à la position en cours.")
riskPct   = input.float(1.0,             "Risque par trade (%)", group = GRP_GEN, minval = 0.05, maxval = 100, step = 0.05, tooltip = "Taille calculée pour que la perte au SL = ce % d'equity. Écrase l'Order size de l'onglet Properties.")
debug     = input.bool(false,            "Debug (afficher les bulles de signal)", group = GRP_GEN, tooltip = "Affiche les ronds sur les cassures/réintégrations détectées (les flèches restent toujours visibles).")
breakOnClose = input.bool(false,         "Cassure de bougie validée en CLÔTURE (sinon mèche/séance)", group = GRP_GEN, tooltip = "S'applique aux DEUX setups. Coché : la bougie suivante doit CLÔTURER au-delà de l'extrême de la bulle. Décoché : il suffit que la mèche le franchisse en séance.")

var string GRP_BREAK = "Cassure"
enableBreak = input.bool(true,  "Activer la cassure (continuation)", group = GRP_BREAK)
tpBreak1    = input.float(1.0,  "TP1 (×range)", group = GRP_BREAK, minval = 0.1, step = 0.1)
tpBreak2    = input.float(2.0,  "TP2 (×range)", group = GRP_BREAK, minval = 0.1, step = 0.1)
tpBreak3    = input.float(5.0,  "TP3 (×range)", group = GRP_BREAK, minval = 0.1, step = 0.1)
slBreakPct  = input.float(55.0, "SL (% range)", group = GRP_BREAK, minval = 0, step = 1, tooltip = "% du range depuis la borne cassée. Non capé : >100 autorisé.")

var string GRP_REINT = "Réintégration"
enableReint = input.bool(true,   "Activer la réintégration (fade)", group = GRP_REINT)
tpReint1    = input.float(0.5,   "TP1 (×range)", group = GRP_REINT, minval = 0.1, step = 0.1)
tpReint2    = input.float(1.0,   "TP2 (×range)", group = GRP_REINT, minval = 0.1, step = 0.1, tooltip = "1.0 = borne opposée du range (l'ancien défaut figé).")
tpReint3    = input.float(2.0,   "TP3 (×range)", group = GRP_REINT, minval = 0.1, step = 0.1)
slReintWick = input.float(100.0, "SL (% mèche)", group = GRP_REINT, minval = 0, step = 5, tooltip = "Fraction de la mèche de l'extrême de la bougie de réintégration, ajoutée au-delà (body si open en extrême). Non capé.")

var string GRP_POS = "Répartition & gestion"
// Modes de break-even (const strings : servent aux options input.string ET aux comparaisons)
BE_NONE  = "Aucune"
BE_TP1   = "Au TP1"
BE_EARLY = "Anticipée (% prix)"
qtyTP1    = input.int(50,   "Sortie TP1 (%)", group = GRP_POS, minval = 0, maxval = 100, tooltip = "TP1+TP2+TP3 doivent totaliser ≤ 100 %. Le reliquat = runner (ou ajouté à TP3 si runner off).")
qtyTP2    = input.int(20,   "Sortie TP2 (%)", group = GRP_POS, minval = 0, maxval = 100)
qtyTP3    = input.int(20,   "Sortie TP3 (%)", group = GRP_POS, minval = 0, maxval = 100)
useRunner = input.bool(true, "Runner (reliquat, sort au stop)", group = GRP_POS, tooltip = "Si off, le reliquat est ajouté à TP3.")
beMode     = input.string(BE_TP1, "Break-even", options = [BE_NONE, BE_TP1, BE_EARLY], group = GRP_POS, tooltip = "Aucune : stop fixe au SL. Au TP1 : BE quand le prix atteint TP1. Anticipée : BE quand le prix a parcouru le % ci-dessous en notre faveur (avant TP1).")
earlyBEPct = input.float(1.0, "BE anticipée — % prix dans notre sens", group = GRP_POS, minval = 0.1, step = 0.1, tooltip = "Utilisé uniquement en mode « Anticipée ». % du prix d'entrée parcouru en notre faveur déclenchant le BE.")

// ============================================================
// Constantes & couleurs
// ============================================================
COL_SL   = color.red
COL_TP   = color.green
COL_GREY = color.gray
TR_DONE_BG = 92   // trade FERMÉ : fond estompé (plus transparent qu'une position vivante)
TR_DONE_BD = 70   // trade FERMÉ : bordure / ligne estompée
RUN_LEAD   = 5    // rayon « taille restante » : étendu (et étiquette posée) à N barres DEVANT la barre courante

// Répartition effective (le reliquat va au runner, ou à TP3 si runner off)
splitBase  = qtyTP1 + qtyTP2 + qtyTP3
remainder  = math.max(0, 100 - splitBase)
runnerPct  = useRunner ? remainder : 0
p3eff      = useRunner ? qtyTP3 : qtyTP3 + remainder
validSplit = splitBase <= 100

// ============================================================
// Type Trade — état d'une position DESSINÉE (niveaux + objets graphiques + cycle de vie)
// ============================================================
type Trade
    string id          // id ordre moteur (strategy.entry / strategy.exit)
    int   dir          // +1 long, -1 short
    float entry
    float sl
    float tp1
    float tp2
    float tp3
    bool  closed       // figée : SL/BE ou TP3 touché
    bool  slGreyed     // BE armé : stop ramené à l'entrée + box SL grisée
    bool  runner       // reliquat runner seul (TP3 atteint) → ne compte plus comme position en cours
    box   bxPos        // box verte entrée→TP3
    box   bxSL         // box rouge entrée→SL
    line  lnT1         // ligne pointillée TP1
    line  lnT2         // ligne pointillée TP2
    line  lnRun        // rayon « taille restante » au niveau d'entrée, tracé dès l'entrée
    label lbRun        // étiquette de la taille restante (live, signée), à l'extrémité du rayon

// Entrée PLACÉE mais pas encore DESSINÉE : on attend la confirmation du fill (liveSize ≠ 0) pour ne
//   dessiner que les trades réellement exécutés (un ordre capé à 0 par le capital ne laisse aucune trace).
type Pending
    string id
    int   dir
    float entry
    float sl
    float tp1
    float tp2
    float tp3
    int   barIdx       // bar_index de l'entrée — sert à détecter le non-fill (barre suivante)
    int   t0           // time de l'entrée — ancre gauche du dessin (la box démarre bien à la bougie-flèche)

// ============================================================
// État persistant (reset au changement de jour chart)
// ============================================================
var int   tradesToday  = 0
var bool  outAbove     = false
var bool  outBelow     = false
var float exHigh       = na
var float exHighWick   = na
var float exLow        = na
var float exLowWick    = na
var bool  brokeUpState = false   // dernière clôture évaluée au-dessus de orH ?
var bool  brokeDnState = false   // dernière clôture évaluée sous orL ?
var bool  cassuredUp   = false   // une bougie a CLÔTURÉ au-dessus de orH (cassure confirmée, pas une mèche) ?
var bool  cassuredDn   = false   // une bougie a CLÔTURÉ sous orL ?
var int   tradeSeq     = 0
var array<Trade> trades = array.new<Trade>()
var array<Pending> pending = array.new<Pending>()   // entrées placées en attente de confirmation de fill

// Compteurs debug (cumulés sur tout le backtest, jamais reset)
var int cntTriggers  = 0   // setups détectés
var int cntPlaced    = 0   // ordres d'entrée placés (marché à la clôture)
var int cntCancelled = 0   // ordres non filés (qty capée à 0 par le capital) → purgés sans trace
var int cntFilled    = 0   // ordres réellement filés (boxes matérialisées)
var int cntSkipOpp   = 0   // skip : sens opposé à la position ouverte
var int cntSkipTp    = 0   // skip : TP déjà derrière l'entrée
var int cntSkipQty   = 0   // skip : qty<=0 ou répartition invalide

// ============================================================
// Calculs de barre (jamais en bloc conditionnel pour ta.*)
// ============================================================
oneBarMs  = timeframe.in_seconds() * 1000
dayChange = ta.change(dayofmonth(time, orTz)) != 0

[orH, orL, _orStart, orEnd, orSeen] = levels.openRange(orTz)
R       = orH - orL
orReady = orSeen and not na(orEnd) and not na(R) and R > 0 and time >= orEnd

// Helpers de rendu (box bornée + ligne horizontale, ancrées en bar_time, étendues manuellement)
mkBox(int lt, float a, float b, color col) => box.new(left = lt, top = math.max(a, b), right = lt + oneBarMs, bottom = math.min(a, b), xloc = xloc.bar_time, border_color = color.new(col, 40), bgcolor = color.new(col, 85), border_width = 1, extend = extend.none, force_overlay = true)
mkLine(int lt, float y, color col) => line.new(x1 = lt, y1 = y, x2 = lt + oneBarMs, y2 = y, xloc = xloc.bar_time, color = color.new(col, 20), width = 1, style = line.style_dashed, force_overlay = true)
mkRay(int lt, int rt, float y, color col) => line.new(x1 = lt, y1 = y, x2 = rt, y2 = y, xloc = xloc.bar_time, color = color.new(col, 10), width = 2, style = line.style_solid, force_overlay = true)

// Ouvre une position DESSINÉE et la tracke dans `trades` : box verte entrée→TP3, box rouge entrée→SL,
//   lignes pointillées TP1/TP2 (selon répartition). Ancrée à la bougie courante (la flèche) ;
//   étendue puis figée barre par barre par la boucle de vie des positions (bas du fichier).
openPos(string id, int dir, float entry, float sl, float tp1, float tp2, float tp3, int lt) =>
    bxP = mkBox(lt, entry, tp3, COL_TP)
    bxS = mkBox(lt, entry, sl,  COL_SL)
    l1  = qtyTP1 > 0 ? mkLine(lt, tp1, COL_TP) : na
    l2  = qtyTP2 > 0 ? mkLine(lt, tp2, COL_TP) : na
    // Rayon « taille restante » au niveau d'entrée (vert long / rouge short), porté RUN_LEAD barres devant.
    //   Dessiné seulement une fois le fill confirmé → la taille (live) est affichée dès la 1re barre du rayon.
    col = dir == 1 ? COL_TP : COL_SL
    rt  = lt + RUN_LEAD * oneBarMs
    lr  = mkRay(lt, rt, entry, col)
    lb  = label.new(x = rt, y = entry, xloc = xloc.bar_time, text = "", style = label.style_label_left, color = color.new(col, 20), textcolor = color.white, size = size.small, force_overlay = true)
    array.push(trades, Trade.new(id = id, dir = dir, entry = entry, sl = sl, tp1 = tp1, tp2 = tp2, tp3 = tp3, closed = false, slGreyed = false, runner = false, bxPos = bxP, bxSL = bxS, lnT1 = l1, lnT2 = l2, lnRun = lr, lbRun = lb))

// Taille par RISQUE : qty telle que la perte au SL (distance entrée↔SL × valeur du point) = riskPct% de l'equity.
//   Retourne 0 si la distance est nulle (setup dégénéré → on n'ouvre pas). Écrase l'Order size des Propriétés.
riskQty(float entry, float sl) =>
    d = math.abs(entry - sl)
    d > 0 ? (strategy.equity * riskPct / 100.0) / (d * syminfo.pointvalue) : 0.0

// Estompe une position FERMÉE (transparence accrue) pour la faire reculer visuellement.
//   SL : reste GRIS si le trade a atteint BE (slGreyed) — sortie à BE = non-événement discret ;
//   sinon ROUGE. Le gris VIF (opaque, 85/45) reste réservé à une position vivante à BE ; ici gris ESTOMPÉ.
fadePos(Trade t) =>
    box.set_bgcolor(t.bxPos, color.new(COL_TP, TR_DONE_BG))
    box.set_border_color(t.bxPos, color.new(COL_TP, TR_DONE_BD))
    slCol = t.slGreyed ? COL_GREY : COL_SL
    box.set_bgcolor(t.bxSL, color.new(slCol, TR_DONE_BG))
    box.set_border_color(t.bxSL, color.new(slCol, TR_DONE_BD))
    if not na(t.lnT1)
        line.set_color(t.lnT1, color.new(COL_TP, TR_DONE_BD))
    if not na(t.lnT2)
        line.set_color(t.lnT2, color.new(COL_TP, TR_DONE_BD))

// Taille réellement encore ouverte pour un ordre d'entrée (somme des positions moteur portant cet id).
//   Signée : négative pour un short. Alimente le label « taille restante » du rayon (décroît aux TP filés).
liveSize(string id) =>
    s = 0.0
    if strategy.opentrades > 0
        for i = 0 to strategy.opentrades - 1
            if strategy.opentrades.entry_id(i) == id
                s += strategy.opentrades.size(i)
    s

// Supprime le rayon + son étiquette à la sortie : aucune trace de « taille restante » sur une position fermée.
delRunner(Trade t) =>
    if not na(t.lnRun)
        line.delete(t.lnRun)
    if not na(t.lbRun)
        label.delete(t.lbRun)

// (helper filledNow retiré — plus de moteur d'ordres à ce stade)

// Marqueurs de signal (série réinitialisée chaque barre) : niveau d'entrée potentiel par sens.
float dbgTrigUp = na   // bulle LONG : extrême (haut) de la bougie de signal
float dbgTrigDn = na   // bulle SHORT : extrême (bas) de la bougie de signal
float dbgFill   = na   // (inutilisé pour l'instant)

// SL/TP du signal de la bougie courante — mémorisés pour les redessiner à la flèche (bougie suivante).
float sigSL  = na   // SL CASSURE (niveau du range). na si réintégration → SL calculé à la flèche.
float sigTP1 = na
float sigTP2 = na
float sigTP3 = na

// ============================================================
// Logique — uniquement sur bougie fermée (pas de repaint)
// ============================================================
if barstate.isconfirmed
    // --- Nouveau jour : reset de l'état de DÉTECTION + du compteur de trades du jour.
    if dayChange
        outAbove     := false
        outBelow     := false
        exHigh       := na
        exHighWick   := na
        exLow        := na
        exLowWick    := na
        brokeUpState := false
        brokeDnState := false
        cassuredUp   := false
        cassuredDn   := false
        tradesToday  := 0

    // (Vie des positions dessinées — extension + fermeture SL/TP3 — gérée en bas, pilotée par les flèches.
    //  Pas de moteur d'ordres ici : ce sera l'étape suivante.)

    // --- 2. Détection des déclencheurs (OR figé) ---
    if orReady
        // Suivi de l'excursion (extrême Dow fadé par une réintégration)
        if high > orH
            if not outAbove
                outAbove   := true
                exHigh     := high
                exHighWick := high - math.max(open, close)
            else if high > exHigh
                exHigh     := high
                exHighWick := high - math.max(open, close)
        if low < orL
            if not outBelow
                outBelow  := true
                exLow     := low
                exLowWick := math.min(open, close) - low
            else if low < exLow
                exLow     := low
                exLowWick := math.min(open, close) - low

        // La CASSURE se déclenche sur la 1re clôture au-delà de la borne (pas à chaque barre dehors).
        firstCloseAbove = close > orH and not brokeUpState
        firstCloseBelow = close < orL and not brokeDnState
        brokeUpState := close > orH
        brokeDnState := close < orL
        // Cassure CONFIRMÉE = une clôture au-delà. Elle arme la réintégration (qui attend un retour dedans).
        if close > orH
            cassuredUp := true
        if close < orL
            cassuredDn := true
        closeInside  = close <= orH and close >= orL
        slBreakDist  = (slBreakPct / 100.0) * R

        // Un déclencheur fige : sens, SL, TPs (ancrés sur l'OR). L'entrée se fait au marché à la
        // clôture de la bougie déclencheuse (proche de la borne OR → cibles toujours du bon côté).
        bool  triggered = false
        int   tDir      = 0
        float tEntry    = na      // niveau du stop = extrême de la bougie de signal (fixé en section 3)
        float tSL       = na
        float tTP1      = na
        float tTP2      = na
        float tTP3      = na
        if enableBreak and firstCloseAbove
            triggered := true
            tDir   := 1
            tSL    := orH - slBreakDist
            tTP1   := orH + tpBreak1 * R
            tTP2   := orH + tpBreak2 * R
            tTP3   := orH + tpBreak3 * R
        else if enableBreak and firstCloseBelow
            triggered := true
            tDir   := -1
            tSL    := orL + slBreakDist
            tTP1   := orL - tpBreak1 * R
            tTP2   := orL - tpBreak2 * R
            tTP3   := orL - tpBreak3 * R
        else if enableReint and closeInside and cassuredUp
            triggered := true                                // cassure confirmée en haut puis retour dedans → short
            tDir   := -1
            upW = high - math.max(open, close)               // mèche HAUTE de la bougie de réintégration (la bulle)
            tSL := high + (slReintWick / 100.0) * (upW > 0 ? upW : math.abs(open - close))   // SL au-dessus (body si open en extrême)
            tTP1   := orH - tpReint1 * R
            tTP2   := orH - tpReint2 * R                     // 1.0 = orL (borne opposée), comme l'ancien figé
            tTP3   := orH - tpReint3 * R
            cassuredUp := false                              // ré-armé : il faudra une NOUVELLE cassure
            outAbove   := false
        else if enableReint and closeInside and cassuredDn
            triggered := true                                // cassure confirmée en bas puis retour dedans → long
            tDir   := 1
            dnW = math.min(open, close) - low                // mèche BASSE de la bougie de réintégration (la bulle)
            tSL := low - (slReintWick / 100.0) * (dnW > 0 ? dnW : math.abs(open - close))    // SL en-dessous (body si open en extrême)
            tTP1   := orL + tpReint1 * R
            tTP2   := orL + tpReint2 * R                     // 1.0 = orH (borne opposée), comme l'ancien figé
            tTP3   := orL + tpReint3 * R
            cassuredDn := false
            outBelow   := false

        // --- 3. BULLES : on marque le niveau d'entrée potentiel (extrême de la bougie de signal).
        //        L'ENTRÉE/LES ORDRES sont retirés — à reconstruire step by step.
        if triggered
            cntTriggers += 1
            tEntry := tDir == 1 ? high : low                 // extrême de la bougie de signal (haut si long, bas si short)
            sigSL  := tSL                                    // SL cassure (niveau range) ; na si réintégration
            sigTP1 := tTP1
            sigTP2 := tTP2
            sigTP3 := tTP3
            if tDir == 1
                dbgTrigUp := tEntry
            else
                dbgTrigDn := tEntry

// ============================================================
// Visualisation de l'Open Range + debug
// ============================================================
plot(orReady ? orH : na, "OR High", color = color.new(color.blue, 0), linewidth = 1, style = plot.style_linebr)
plot(orReady ? orL : na, "OR Low",  color = color.new(color.blue, 0), linewidth = 1, style = plot.style_linebr)
// BULLES : ronds au niveau d'entrée potentiel — lime = signal long (cassure haute / réintég basse),
//          rouge = signal short (cassure basse / réintég haute). Marquent les cassures et réintégrations.
plot(debug ? dbgTrigUp : na, "Signal long",  color = color.new(color.lime, 0), style = plot.style_circles, linewidth = 3)
plot(debug ? dbgTrigDn : na, "Signal short", color = color.new(color.red,  0), style = plot.style_circles, linewidth = 3)

// FLÈCHES : la bougie de bulle est-elle cassée par la bougie SUIVANTE (celle-ci) ?
//   - bulle verte (long) cassée par le HAUT  : high de cette bougie > high de la bulle  → flèche up
//   - bulle rouge (short) cassée par le BAS   : low de cette bougie  < low de la bulle   → flèche down
breakUp = not na(dbgTrigUp[1]) and (breakOnClose ? close > dbgTrigUp[1] : high > dbgTrigUp[1])
breakDn = not na(dbgTrigDn[1]) and (breakOnClose ? close < dbgTrigDn[1] : low  < dbgTrigDn[1])
plotshape(breakUp, "Breakup",   style = shape.arrowup,   location = location.belowbar, color = color.new(color.lime, 0), size = size.small)
plotshape(breakDn, "Breakdown", style = shape.arrowdown, location = location.abovebar, color = color.new(color.red,  0), size = size.small)

// VIE DE LA POSITION dessinée — uniquement sur bougie fermée (pas de doublon en temps réel).
//   À chaque flèche on ouvre une position : entrée = close de la bougie-flèche si validation en
//   clôture, sinon le niveau cassé (extrême de la bulle) ; SL/TP du signal figés sur la bulle (lus en [1]).
if barstate.isconfirmed
    // Résolution des entrées en attente : on ne DESSINE qu'une fois le fill confirmé (liveSize ≠ 0),
    //   ancré à la bougie d'entrée (p.t0). Tourne AVANT les plafonds pour que les fills soient comptés.
    //   Un ordre non filé (qty capée à 0 par le capital) est purgé dès la barre suivante → aucune trace.
    if array.size(pending) > 0
        for pi = array.size(pending) - 1 to 0
            p = array.get(pending, pi)
            if liveSize(p.id) != 0
                openPos(p.id, p.dir, p.entry, p.sl, p.tp1, p.tp2, p.tp3, p.t0)
                array.remove(pending, pi)
                cntFilled += 1
            else if bar_index > p.barIdx
                array.remove(pending, pi)
                cntCancelled += 1

    // Plafonds : `tradesMax` trades ouverts/jour, `maxOpen` positions simultanées (renfort).
    //   array.size(trades) = positions encore ouvertes (les fermées sont purgées plus bas).
    // Garde-fou : on rejette le setup si le TP1 est déjà DERRIÈRE l'entrée (entrée au-delà de la 1re cible).
    // Positions « en cours » = ouvertes NON-runner (un runner de-riské ne compte pas : ni slot maxOpen, ni sens).
    //   openCount = leur nombre ; netDir = leur sens (+1 long / -1 short, 0 si aucune) — ne sert qu'au mode « net ».
    int openCount = 0
    int netDir    = 0
    for t in trades
        if not t.runner
            openCount += 1
            netDir := t.dir
    allowLong  = validSplit and dirMode != DIR_SHORT and (dirMode != DIR_NET or netDir >= 0)
    allowShort = validSplit and dirMode != DIR_LONG  and (dirMode != DIR_NET or netDir <= 0)
    if breakUp and tradesToday < tradesMax and openCount < maxOpen and allowLong
        eUp = breakOnClose ? close : dbgTrigUp[1]
        qUp = riskQty(eUp, sigSL[1])
        if sigTP1[1] > eUp and qUp > 0                   // TP1 devant l'entrée (long) + taille calculable
            eid = str.tostring(bar_index) + "L"
            strategy.entry(eid, strategy.long, qty = qUp)   // marché à la clôture, taille par risque
            array.push(pending, Pending.new(id = eid, dir = 1, entry = eUp, sl = sigSL[1], tp1 = sigTP1[1], tp2 = sigTP2[1], tp3 = sigTP3[1], barIdx = bar_index, t0 = time))
            tradesToday += 1
            cntPlaced += 1
    if breakDn and tradesToday < tradesMax and openCount < maxOpen and allowShort
        eDn = breakOnClose ? close : dbgTrigDn[1]
        qDn = riskQty(eDn, sigSL[1])
        if sigTP1[1] < eDn and qDn > 0                   // TP1 devant l'entrée (short) + taille calculable
            eid = str.tostring(bar_index) + "S"
            strategy.entry(eid, strategy.short, qty = qDn)
            array.push(pending, Pending.new(id = eid, dir = -1, entry = eDn, sl = sigSL[1], tp1 = sigTP1[1], tp2 = sigTP2[1], tp3 = sigTP3[1], barIdx = bar_index, t0 = time))
            tradesToday += 1
            cntPlaced += 1

    // Chaque barre fermée : étendre les positions ouvertes (même bord droit), armer le BE (anticipé
    //   % prix OU au TP1 → stop à l'entrée, box SL grisée — réservé à une position VIVANTE), et FIGER au stop
    //   courant (SL/BE) ou au TP3 → la position fermée est ESTOMPÉE (couleurs gardées, plus transparentes).
    if array.size(trades) > 0
        rx = time + oneBarMs
        for t in trades
            if not t.closed
                // Rayon « taille restante » (niveau d'entrée, depuis l'entrée) : porté RUN_LEAD barres devant
                //   la barre courante ; le label suit la taille réellement ouverte (décroît à chaque TP filé).
                rxRun = time + RUN_LEAD * oneBarMs
                line.set_x2(t.lnRun, rxRun)
                label.set_x(t.lbRun, rxRun)
                ls = liveSize(t.id)
                if ls != 0
                    label.set_text(t.lbRun, str.tostring(ls, "#.###"))
                // Boxes + lignes TP : étendues tant que le trade principal vit ; figées au TP3 (le rayon prend le relais).
                if not t.runner
                    box.set_right(t.bxPos, rx)
                    box.set_right(t.bxSL, rx)
                    if not na(t.lnT1)
                        line.set_x2(t.lnT1, rx)
                    if not na(t.lnT2)
                        line.set_x2(t.lnT2, rx)
                // Stop courant : SL d'origine, ou BE (= entrée) une fois la position sécurisée (slGreyed).
                //   BE armé à la barre QUI SUIT le déclencheur (enregistré en fin de barre, après le test du stop).
                stopNow = t.slGreyed ? t.entry : t.sl
                // Sorties partielles moteur (stop COMMUN, suit le BE) : TP1/TP2/TP3 en limites + runner au stop/BE.
                //   qty_percent = % de la position d'origine ; replacées chaque barre pour répercuter le stop courant.
                if qtyTP1 > 0
                    strategy.exit("t1" + t.id, from_entry = t.id, qty_percent = qtyTP1, stop = stopNow, limit = t.tp1)
                if qtyTP2 > 0
                    strategy.exit("t2" + t.id, from_entry = t.id, qty_percent = qtyTP2, stop = stopNow, limit = t.tp2)
                if p3eff > 0
                    strategy.exit("t3" + t.id, from_entry = t.id, qty_percent = p3eff, stop = stopNow, limit = t.tp3)
                if runnerPct > 0
                    strategy.exit("tr" + t.id, from_entry = t.id, qty_percent = runnerPct, stop = stopNow)
                stopHit = t.dir == 1 ? low  <= stopNow : high >= stopNow
                tp3Hit  = t.dir == 1 ? high >= t.tp3   : low  <= t.tp3
                // Sortie : stop/BE (toute phase) ou TP3 sans runner. Le runner, lui, ne sort QUE par le stop.
                if stopHit or (runnerPct == 0 and tp3Hit)
                    t.closed := true
                    if not t.runner
                        fadePos(t)                               // boxes pas encore estompées (sortie avant le TP3)
                    delRunner(t)                                 // supprime le rayon + label (rien sur une position fermée)
                else
                    // Naissance du runner (TP3 atteint, reliquat alloué) : on FIGE+estompe la box principale
                    //   (le gros du trade est fini) ; le rayon « taille restante » continue de courir.
                    if runnerPct > 0 and tp3Hit and not t.runner
                        t.runner := true
                        fadePos(t)
                    // BE : arme au premier déclencheur (anticipé = avant TP1) si pas encore sécurisée.
                    if not t.slGreyed
                        beEarlyLvl = t.dir == 1 ? t.entry * (1 + earlyBEPct / 100.0) : t.entry * (1 - earlyBEPct / 100.0)
                        beEarly    = beMode == BE_EARLY and (t.dir == 1 ? high >= beEarlyLvl : low <= beEarlyLvl)
                        beAtTp1    = beMode == BE_TP1   and (t.dir == 1 ? high >= t.tp1 : low <= t.tp1)
                        if beEarly or beAtTp1
                            t.slGreyed := true                   // BE armé → box SL grisée (risque éteint, position VIVANTE)
                            box.set_bgcolor(t.bxSL, color.new(COL_GREY, 85))
                            box.set_border_color(t.bxSL, color.new(COL_GREY, 45))
        // Purge des positions figées (boxes déjà dessinées, gelées à leur dernier bord droit).
        for i = array.size(trades) - 1 to 0
            if array.get(trades, i).closed
                array.remove(trades, i)
