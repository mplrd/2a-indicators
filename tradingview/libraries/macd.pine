//@version=6
// @description lib-macd — MACD et variantes. Couche 1, ne dessine pas.
//              Délègue les moyennes mobiles à `lib_ma` (DEMA pour les variantes Zero Lag).
library("lib_macd", overlay = false)

import mpilard/lib_ma/3 as ma

// ============================================================
// MACD Zero Retard (Zero Lag MACD / MACD ZR)
// ============================================================

// @function MACD Zero Retard — variante du MACD classique qui remplace les EMA fast/slow ET la
//           signal line par des DEMA, ce qui réduit le lag inhérent au MACD EMA-based.
//           Formule (portée d'un indicateur de référence validé) :
//             - demaFast = DEMA(src, fastLen)
//             - demaSlow = DEMA(src, slowLen)
//             - macd     = demaFast - demaSlow
//             - signal   = DEMA(macd, signalLen)   (et non EMA — c'est le « zero retard »)
//             - hist     = macd - signal
//             - average  = SMA(macd, signalLen)    (référence lente sur l'oscillateur lui-même)
// @param src        Série source (typiquement close).
// @param fastLen    Période DEMA rapide (défaut 12).
// @param slowLen    Période DEMA lente (défaut 26).
// @param signalLen  Période du signal (DEMA du MACD) ET de la moving average SMA (défaut 9).
// @returns [macd, signal, histogram, average].
export zeroRetard(series float src, simple int fastLen, simple int slowLen, simple int signalLen) =>
    demaFast = ma.dema(src, fastLen)
    demaSlow = ma.dema(src, slowLen)
    macd     = demaFast - demaSlow
    signal   = ma.dema(macd, signalLen)
    hist     = macd - signal
    average  = ta.sma(macd, signalLen)
    [macd, signal, hist, average]
