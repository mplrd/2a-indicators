//@version=6
// @description lib-market — détection automatique du type d'instrument (cash EU/US/Asia ou non-cash). Couche 0.
//              Aucune dépendance lib. La détection est sticky (calculée une fois, persiste).
library("lib_market", overlay = true)

// ============================================================
// Types
// ============================================================

// @enum MarketType — Classification d'un instrument.
export enum MarketType
    CASH_EU
    CASH_US
    CASH_ASIA
    NON_CASH

// ============================================================
// Détection
// ============================================================

// @function Détecte le type de marché en se basant sur `syminfo.type` + `syminfo.timezone` —
//           valeurs FIXES par instrument, données par TradingView. Beaucoup plus fiable qu'un
//           algorithme basé sur les bougies (qui dépend de TF/alignement/extended hours).
//
//           Logique :
//           - `syminfo.type` ∈ {"crypto", "forex"}                   → NON_CASH (continu 24h, pas de cash session)
//           - sinon `syminfo.timezone` commence par "America/"       → CASH_US
//           - sinon `syminfo.timezone` commence par "Europe/"        → CASH_EU
//           - sinon `syminfo.timezone` commence par "Asia/" ou "Australia/" → CASH_ASIA
//           - sinon                                                  → NON_CASH (fallback)
//
//           Cas particuliers :
//           - Futures NYMEX/CBOT/CME (syminfo.timezone = America/New_York ou America/Chicago) →
//             classés CASH_US. C'est intentionnel : l'OPR à 9h30 NY est l'événement de référence
//             pour les futures sur indices US.
//           - Indices européens (DAX, CAC, FTSE) → CASH_EU via TZ Europe/*.
//
// @returns MarketType (sticky)
export detect() =>
    var MarketType marketType = MarketType.NON_CASH
    var bool detected = false

    if not detected
        symType = syminfo.type
        tz      = syminfo.timezone

        if symType == "crypto" or symType == "forex"
            marketType := MarketType.NON_CASH
        else if str.startswith(tz, "America/")
            marketType := MarketType.CASH_US
        else if str.startswith(tz, "Europe/")
            marketType := MarketType.CASH_EU
        else if str.startswith(tz, "Asia/") or str.startswith(tz, "Australia/")
            marketType := MarketType.CASH_ASIA
        else
            marketType := MarketType.NON_CASH

        detected := true

    marketType

// @function Vrai si le type détecté correspond à un marché cash (EU, US ou Asia).
export isCash(MarketType mt) =>
    mt == MarketType.CASH_EU or mt == MarketType.CASH_US or mt == MarketType.CASH_ASIA
