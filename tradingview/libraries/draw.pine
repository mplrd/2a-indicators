//@version=6
// @description lib-draw — primitives de rendu : styles, couleurs, helpers de niveaux et de zones.
//              Couche 2 (aucune logique métier, dessine ce qu'on lui passe).
library("lib_draw", overlay = true)

// Pas d'import UDT — `drawZoneBox` prend des primitives (left/top/bottom/isActive) plutôt qu'un
// type concret. lib_draw reste agnostique de `lib_zone` / `lib_cmi_zone` ; les callers déballent
// leur UDT au call site. Plus simple à porter sur cTrader/MT4 ensuite.

// ============================================================
// Styles de ligne — enum + helpers
// ============================================================

// @enum LineStyle — Style de ligne pour `line.new()`, `hline()` et `plot()`.
//                   Les titres de membres sont les symboles ASCII utilisés dans les dropdowns Pine
//                   (`input.enum()`) afin que l'utilisateur visualise directement le style choisi.
export enum LineStyle
    SOLID  = "⎯⎯⎯"
    DASHED = "----"
    DOTTED = "····"

// NB — pas d'équivalent `plotLineStyle()` exportable depuis cette lib :
//      `plot(..., linestyle = ...)` exige un `input plot_line_style`. Or Pine n'autorise pas le
//      qualifier `input` sur les params d'exports de lib (CE10160) — seuls `simple` et `series` sont
//      acceptés. Un wrapper de lib retourne donc `simple`, refusé par `plot()` (CE10123).
//      Conséquence : la conversion `LineStyle` → `plot.linestyle_*` doit rester INLINE dans l'indicateur.
//      Pattern type-safe côté indicateur :
//          myLS = myEnumInput == draw.LineStyle.DASHED ? plot.linestyle_dashed :
//                 myEnumInput == draw.LineStyle.DOTTED ? plot.linestyle_dotted : plot.linestyle_solid
//      Ça reste robuste car on compare contre des membres d'enum (pas des strings magiques).

// ============================================================
// Couleurs
// ============================================================

// @function Couleur d'une bande Bollinger selon son état (plate / en fermeture) et son côté (haute / basse).
//           Quand la bande est ouverte → baseColor. Quand elle est plate ou en fermeture → bull (bande basse)
//           ou bear (bande haute). Note : `isFlat` et `isClosing` sont supposés mutuellement exclusifs
//           (cf. lib-ma.isFlatSeries / isClosingSeries) mais l'union est tolérée.
// @param baseColor Couleur par défaut (bande ouverte).
// @param bullColor Couleur appliquée à une bande basse plate/en fermeture.
// @param bearColor Couleur appliquée à une bande haute plate/en fermeture.
// @param isFlat    Bande plate ?
// @param isClosing Bande en fermeture ?
// @param isUpper   true = bande supérieure, false = bande inférieure.
// @returns color
export bandColor(series color baseColor, series color bullColor, series color bearColor, series bool isFlat, series bool isClosing, simple bool isUpper) =>
    isFlat or isClosing ? (isUpper ? bearColor : bullColor) : baseColor

// ============================================================
// Niveaux horizontaux — choix start / extension
// ============================================================

// @function (privé) Détermine où commencer une ligne de niveau et avec quelle extension :
//           - Si le point d'origine est connu, valide, et dans les 365 dernières barres
//             → la ligne part de `startBar` et s'étend à droite (`extend.right`).
//           - Sinon (origine inconnue, trop ancienne, ou hors plage du chart courant)
//             → la ligne part de la barre courante et s'étend des deux côtés (`extend.both`).
//           Ce pattern permet de toujours dessiner un niveau même quand sa barre d'origine
//           n'est pas visible dans la TF courante (ex : ATH atteint il y a des années).
//           Utilisé en interne par `drawLevel`.
resolveLevelStartAndExtend(series int startBar, series bool startBarFound) =>
    drawable = startBarFound and not na(startBar) and startBar >= 0 and startBar <= bar_index and (bar_index - startBar) <= 365
    [drawable ? startBar : bar_index, drawable ? extend.right : extend.both]

// @function Dessine un niveau horizontal sur la dernière barre + un label optionnel.
//           Gère la règle des 365 barres via `resolveLevelStartAndExtend` (extend.right / extend.both).
//           Conversion `LineStyle` → `line.style_*` inlinée DIRECTEMENT dans `line.new(style = ...)`
//           (CE10123 sinon si la conversion passe par une variable intermédiaire dans une lib).
//           Retourne la `line` créée (ou `na`) — type non-plottable, donc Pine n'affiche pas
//           le nom de la fonction dans le data window au call site.
// @param show          Toggle global : dessiner ou non.
// @param price         Prix du niveau (`na` ignore le rendu).
// @param startBar      Index de la barre d'origine du niveau (peut être `na`).
// @param startBarFound Origine tracable ?
// @param col           Couleur de la ligne (et du label si présent).
// @param width         Épaisseur de ligne.
// @param styleEnum     Style de ligne (`LineStyle.SOLID` / `.DASHED` / `.DOTTED`).
// @param lbl           Texte du label. `""` = pas de label même si `showLbl = true`.
// @param showLbl       Toggle global d'affichage des labels.
// @param lineArr       Array des lignes pour gestion FIFO côté caller (push uniquement).
// @param labelArr      Array des labels (push uniquement).
// @returns series line — la ligne créée ou `na` si rien dessiné.
export drawLevel(series bool show, float price, int startBar, bool startBarFound, series color col, simple int width, simple LineStyle styleEnum, simple string lbl, simple bool showLbl, simple bool isHigh, array<line> lineArr, array<label> labelArr) =>
    line ln = na
    if show and not na(price)
        [startX, extendMode] = resolveLevelStartAndExtend(startBar, startBarFound)
        ln := line.new(
          x1 = startX, y1 = price, x2 = bar_index + 5, y2 = price,
          xloc = xloc.bar_index, extend = extendMode,
          color = col, width = width,
          style = styleEnum == LineStyle.DASHED ? line.style_dashed : styleEnum == LineStyle.DOTTED ? line.style_dotted : line.style_solid,
          force_overlay = true)
        array.push(lineArr, ln)
        if showLbl and lbl != ""
            // isHigh = body au-dessus de la ligne (style_label_down), !isHigh = en-dessous (style_label_up).
            // Body coloré à la couleur du niveau, texte blanc.
            lb = label.new(
              x = bar_index + 20, y = price, text = lbl,
              xloc = xloc.bar_index,
              style = isHigh ? label.style_label_down : label.style_label_up,
              color = col, textcolor = color.white, size = size.small,
              force_overlay = true)
            array.push(labelArr, lb)
    ln

// @function Dessine un niveau horizontal avec **couleur et position de label dynamiques** selon
//           la position de `price` par rapport au `close` courant.
//           - `price > close` (niveau au-dessus du prix = résistance) → couleur `bearColor`,
//             label au-dessus de la ligne (`isHigh = true`).
//           - `price <= close` (niveau en-dessous = support)          → couleur `bullColor`,
//             label en-dessous (`isHigh = false`).
//           Implémenté via 2 appels `drawLevel` mutuellement exclusifs sur `show` (Pine n'accepte
//           pas un `simple bool` dérivé d'une `series` pour `isHigh`). Seul un des deux dessine.
// @param show       Toggle global (peut être series).
// @param price      Prix du niveau.
// @param bullColor  Couleur pour un niveau de SUPPORT (sous le prix).
// @param bearColor  Couleur pour un niveau de RÉSISTANCE (au-dessus du prix).
// @param width      Épaisseur de ligne.
// @param styleEnum  Style de ligne.
// @param lbl        Texte du label.
// @param showLbl    Toggle d'affichage du label.
// @param lineArr    Array des lignes (push).
// @param labelArr   Array des labels (push).
export drawDynamicLevel(series bool show, float price, series color bullColor, series color bearColor, simple int width, simple LineStyle styleEnum, simple string lbl, simple bool showLbl, array<line> lineArr, array<label> labelArr) =>
    above = price > close
    col   = above ? bearColor : bullColor
    naBar = int(na)
    drawLevel(show and above,       price, naBar, false, col, width, styleEnum, lbl, showLbl, true,  lineArr, labelArr)
    drawLevel(show and (not above), price, naBar, false, col, width, styleEnum, lbl, showLbl, false, lineArr, labelArr)

// @function Dessine un niveau horizontal borné dans le temps (sessions, open range, opens).
//           - Si `ongoing = true` : la ligne s'étend à droite (session en cours). Le label est
//             placé à `bar_index + 20` en `xloc.bar_index` (aligné avec `drawLevel`).
//           - Si `ongoing = false` : la ligne s'arrête à `endTime` (session terminée / range figé).
//             Le label est placé à `endTime` en `xloc.bar_time` (étiquette en bout de ligne).
//             Si `endTime` est `na`, rien n'est dessiné.
// @param show       Toggle global.
// @param price      Prix du niveau.
// @param startTime  Timestamp ms d'origine.
// @param endTime    Timestamp ms de fin (utilisé seulement si `ongoing = false`).
// @param ongoing    `true` = session en cours (extend.right), `false` = bornée à endTime.
// @param col        Couleur.
// @param width      Épaisseur.
// @param styleEnum  Style de ligne.
// @param lbl        Texte du label (`""` = pas de label).
// @param showLbl    Toggle global d'affichage des labels.
// @param lineArr    Array des lignes (push).
// @param labelArr   Array des labels (push).
// @returns series line — la ligne créée ou `na`.
export drawSessionLevel(series bool show, float price, int startTime, int endTime, series bool ongoing, series color col, simple int width, simple LineStyle styleEnum, simple string lbl, simple bool showLbl, simple bool isHigh, array<line> lineArr, array<label> labelArr) =>
    line ln = na
    drawable = show and not na(price) and not na(startTime) and (ongoing or not na(endTime))
    if drawable
        oneBarMs = timeframe.in_seconds() * 1000
        x2_val   = ongoing ? time + oneBarMs * 5 : endTime
        ext      = ongoing ? extend.right : extend.none
        ln := line.new(
          x1 = startTime, y1 = price, x2 = x2_val, y2 = price,
          xloc = xloc.bar_time, extend = ext,
          color = col, width = width,
          style = styleEnum == LineStyle.DASHED ? line.style_dashed : styleEnum == LineStyle.DOTTED ? line.style_dotted : line.style_solid,
          force_overlay = true)
        array.push(lineArr, ln)
        if showLbl and lbl != ""
            labelStyle = isHigh ? label.style_label_down : label.style_label_up
            if ongoing
                lb = label.new(
                  x = bar_index + 20, y = price, text = lbl,
                  xloc = xloc.bar_index, style = labelStyle,
                  color = col, textcolor = color.white, size = size.small,
                  force_overlay = true)
                array.push(labelArr, lb)
            else
                lb = label.new(
                  x = endTime, y = price, text = lbl,
                  xloc = xloc.bar_time, style = labelStyle,
                  color = col, textcolor = color.white, size = size.small,
                  force_overlay = true)
                array.push(labelArr, lb)
    ln

// ============================================================
// Zones — rendu d'un rectangle en `box` (primitive agnostique du type d'origine)
// ============================================================

// @function Dessine un rectangle (box) ancré à `leftTime`, étendu à droite. Ne dessine RIEN si
//           `show` est faux ou si `isActive` est faux ou si une coordonnée est `na`. Le label
//           (optionnel) est placé à droite du chart, centré verticalement sur la zone.
//           Cette primitive est agnostique du type UDT (Zone, CmiZone, futurs) : le caller
//           déballe son UDT et passe les champs en primitives. Évite la duplication entre
//           `drawZone(z.Zone)` et `drawCmiZone(cz.CmiZone)`.
// @param show         Toggle global (peut intégrer un filtre côté caller).
// @param isActive     true = la zone est encore vivante (caller : `zone.isActive(z)` ou
//                     `cz.state == cmiZone.CmiState.ACTIVE`).
// @param leftTime     Timestamp ms de la barre d'origine (xloc.bar_time).
// @param top          Borne haute du rectangle.
// @param bottom       Borne basse du rectangle.
// @param col          Couleur de bordure et fond.
// @param borderWidth  Épaisseur de bordure (0 = invisible).
// @param borderStyle  Style de bordure (`LineStyle.SOLID` / `DASHED` / `DOTTED`).
// @param bgAlpha      Transparence du fond (0 = opaque, 100 = invisible).
// @param borderAlpha  Transparence de la bordure.
// @param showLbl      Toggle d'affichage du label.
// @param lbl          Texte du label (ex : "S/D bull"). `""` = pas de label même si `showLbl=true`.
// @param boxArr       Array des boxes (push uniquement, le caller gère le nettoyage).
// @param labelArr     Array des labels (push uniquement).
// @returns series box — la box créée ou `na`.
export drawZoneBox(series bool show, series bool isActive, int leftTime, float top, float bottom, series color col, simple int borderWidth, simple LineStyle borderStyle, simple int bgAlpha, simple int borderAlpha, simple bool showLbl, series string lbl, array<box> boxArr, array<label> labelArr) =>
    box bx = na
    if show and isActive and not na(leftTime) and not na(top) and not na(bottom)
        oneBarMs = timeframe.in_seconds() * 1000
        bx := box.new(
          left = leftTime, top = top, right = time + oneBarMs * 5, bottom = bottom,
          xloc = xloc.bar_time,
          border_color = color.new(col, borderAlpha),
          bgcolor = color.new(col, bgAlpha),
          border_width = borderWidth,
          border_style = borderStyle == LineStyle.DASHED ? line.style_dashed : borderStyle == LineStyle.DOTTED ? line.style_dotted : line.style_solid,
          extend = extend.right,
          force_overlay = true)
        array.push(boxArr, bx)
        if showLbl and lbl != ""
            lb = label.new(
              x = bar_index + 20, y = (top + bottom) / 2.0, text = lbl,
              xloc = xloc.bar_index, style = label.style_label_center,
              color = col, textcolor = color.white, size = size.small,
              force_overlay = true)
            array.push(labelArr, lb)
    bx

// ============================================================
// Gaps — rendu d'un gap journalier en `box` (primitive, ancrée en bar_index)
// ============================================================

// @function Dessine un gap en `box` rectangulaire. Ancre `xloc.bar_index` (différent de `drawZoneBox`
//           qui est en `xloc.bar_time`) car le gap est positionné par rapport à la barre adjacente
//           qui le précède. Pas de bordure (`border_color = na`), juste un fond avec transparence.
//           Étendu à droite (extend.right) pour rester visible tant que le gap n'est pas comblé.
// @param show         Toggle global.
// @param leftBarIndex `bar_index` de la barre AVANT le gap (ancre adjacente).
// @param top          Borne haute.
// @param bottom       Borne basse.
// @param col          Couleur de fond.
// @param bgAlpha      Transparence du fond (0 = opaque, 100 = invisible).
// @param boxArr       Array des boxes (push uniquement, le caller gère le nettoyage).
// @returns series box — la box créée ou `na`.
export drawGapBox(series bool show, int leftBarIndex, float top, float bottom, series color col, simple int bgAlpha, array<box> boxArr) =>
    box bx = na
    if show and not na(leftBarIndex) and not na(top) and not na(bottom)
        bx := box.new(
          left = leftBarIndex, top = top, right = bar_index, bottom = bottom,
          xloc = xloc.bar_index,
          border_color = na,
          bgcolor = color.new(col, bgAlpha),
          extend = extend.right,
          force_overlay = true)
        array.push(boxArr, bx)
    bx

// ============================================================
// Projections — lignes pointillées de projection (MA/BB futures)
// ============================================================

// @function Dessine une ligne pointillée de projection entre deux points en `xloc.bar_index`.
//           Style hardcodé `line.style_dotted` (les projections sont conventionnellement en pointillé).
// @param show     Toggle global.
// @param x1       bar_index gauche.
// @param y1       Prix gauche.
// @param x2       bar_index droite (typiquement bar_index + barsAhead).
// @param y2       Prix droite (valeur projetée).
// @param col      Couleur de ligne.
// @param width    Épaisseur (1-5).
// @param lineArr  Array des lignes (push).
// @returns series line — la ligne créée ou `na`.
export drawProjection(series bool show, int x1, float y1, int x2, float y2, series color col, simple int width, array<line> lineArr) =>
    line ln = na
    if show and not na(y1) and not na(y2)
        ln := line.new(x1, y1, x2, y2, xloc = xloc.bar_index, color = col, style = line.style_dotted, width = width, force_overlay = true)
        array.push(lineArr, ln)
    ln

// ============================================================
// Cleanup — suppression FIFO d'arrays d'objets graphiques
// ============================================================

// @function Supprime toutes les boxes de `boxArr` (box.delete + array.clear). À appeler en début
//           de bloc de rendu islast pour repartir d'une collection vide avant de re-pousser.
// @param boxArr Array des boxes (mutation in place).
export clearBoxes(array<box> boxArr) =>
    for bx in boxArr
        box.delete(bx)
    array.clear(boxArr)

// @function Supprime toutes les lignes de `lineArr` (line.delete + array.clear).
// @param lineArr Array des lignes (mutation in place).
export clearLines(array<line> lineArr) =>
    for ln in lineArr
        line.delete(ln)
    array.clear(lineArr)

// @function Supprime tous les labels de `labelArr` (label.delete + array.clear).
// @param labelArr Array des labels (mutation in place).
export clearLabels(array<label> labelArr) =>
    for lb in labelArr
        label.delete(lb)
    array.clear(labelArr)

// ============================================================
// Plots de bandes (BB / MA) — NON wrappés en lib
// ============================================================
// Note : Pine v6 exige `input plot_line_style` pour `plot(..., linestyle = ...)`. Une lib ne peut
//        pas qualifier ses params `input` (CE10160), et un `simple plot_line_style` calculé en
//        interne est refusé par plot (CE10123). Tant que l'indicateur expose un input.enum de
//        style à l'utilisateur, le `plot(linestyle = ...)` doit rester au call site — c'est une
//        contrainte plateforme, pas un manque de discipline. Les helpers `plotBollingerRibbon`,
//        `plotBollingerLines`, `plotMARibbon`, `plotMALines` (esquissés en v17 puis retirés) ne
//        couvrent en pratique qu'un cas où le style serait câblé dans la lib — pas applicable
//        ici. À réintroduire si un futur indicateur a un design qui s'en accommode.

// ============================================================
// Ichimoku — wrapper plot Tenkan / Kijun / Senkou A / Senkou B / Chikou + fill Kumo
// ============================================================

// @function Dessine les 5 lignes Ichimoku + le Kumo (fill Senkou A vs B). Tenkan/Kijun/Chikou en
//           SOLID, Senkou A/B en SOLID décalés `kijunOffset` barres en avant, fill Kumo entre A et B.
//           Chikou décalé `-kijunOffset` barres en arrière.
//           NB : `display` est calculé en interne via `on ? display.all : display.none` plutôt
//                que pris en param — Pine v6 ne reconnaît plus `plot_display` comme keyword de
//                type (CE10149), et le `display` param de plot() n'accepte pas un `simple` calculé.
// @param tenkan       Série Tenkan.
// @param kijun        Série Kijun.
// @param senkouA      Série Senkou Span A.
// @param senkouB      Série Senkou Span B.
// @param chikou       Série Chikou Span.
// @param tenkanCol    Couleur Tenkan.
// @param kijunCol     Couleur Kijun.
// @param senkouACol   Couleur Senkou A.
// @param senkouBCol   Couleur Senkou B.
// @param kumoCol      Couleur du fill Kumo (déjà avec transparence).
// @param chikouCol    Couleur Chikou.
// @param kijunOffset  Période Kijun (pour le décalage des Senkou et du Chikou).
// @param mainOn       true → Tenkan/Kijun/Senkou/Kumo visibles. false → display.none sur tout le bloc principal.
// @param chikouOn     true → Chikou visible. false → display.none sur Chikou (peut être indépendant du main).
export plotIchimoku(series float tenkan, series float kijun, series float senkouA, series float senkouB, series float chikou, series color tenkanCol, series color kijunCol, series color senkouACol, series color senkouBCol, series color kumoCol, series color chikouCol, simple int kijunOffset, simple bool mainOn, simple bool chikouOn) =>
    plot(tenkan, "Tenkan", color = tenkanCol, linewidth = 1, display = mainOn ? display.all : display.none)
    plot(kijun,  "Kijun",  color = kijunCol,  linewidth = 1, display = mainOn ? display.all : display.none)
    pSenkouA = plot(senkouA, "Senkou A", color = senkouACol, linewidth = 1, offset = kijunOffset, display = mainOn ? display.all : display.none)
    pSenkouB = plot(senkouB, "Senkou B", color = senkouBCol, linewidth = 1, offset = kijunOffset, display = mainOn ? display.all : display.none)
    fill(pSenkouA, pSenkouB, color = kumoCol, title = "Kumo", display = mainOn ? display.all : display.none)
    plot(chikou, "Chikou", color = chikouCol, linewidth = 1, offset = -kijunOffset, display = chikouOn ? display.all : display.none)

// ============================================================
// Supertrend — wrapper plot en style linebr
// ============================================================

// @function Dessine la ligne Supertrend avec interruption (`plot.style_linebr`) — la ligne s'interrompt
//           sur les changements de direction (les `na` ne sont pas connectés).
// @param value    Série Supertrend (mise à `na` en dehors du contexte d'affichage par le caller).
// @param col      Couleur (typiquement bull/bear selon dir).
// @param width    Épaisseur.
// @param on       true → display.all. false → display.none.
export plotSupertrend(series float value, series color col, simple int width, simple bool on) =>
    plot(value, "Supertrend", color = col, linewidth = width, style = plot.style_linebr, display = on ? display.all : display.none)
