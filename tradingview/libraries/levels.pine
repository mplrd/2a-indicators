//@version=6
// @description lib-levels — extraction des niveaux de prix passés : PDH/PDL, PWH/PWL, PMH/PML, ATH,
//              + H/L de sessions (Asian/EU/US). Couche 1, dépend de lib_time pour les helpers de session.
//              Toutes les fonctions sont anti-repaint par construction.
library("lib_levels", overlay = true)

import mpilard/lib_time/2 as tm

// ============================================================
// Niveaux de période précédente (Daily / Weekly / Monthly)
// ============================================================

// @function High et Low de la période PRÉCÉDENTE dans le timeframe demandé.
//           Combinaison anti-repaint standard : on lit `high[1]` / `low[1]` à la TF cible avec
//           `lookahead_on` — la valeur retournée est figée dès l'ouverture de la période courante.
// @param tf Timeframe Pine du niveau supérieur ("D" pour daily, "W" pour weekly, "M" pour monthly).
// @returns [prevHigh, prevLow]
export previousPeriodHL(simple string tf) =>
    pH = request.security(syminfo.tickerid, tf, high[1], lookahead = barmerge.lookahead_on)
    pL = request.security(syminfo.tickerid, tf, low[1],  lookahead = barmerge.lookahead_on)
    [pH, pL]

// @function Timestamp ms du DÉBUT de la période précédente. Sert à dessiner la ligne du niveau
//           depuis le bon point d'origine quand on utilise `xloc.bar_time`.
// @param tf Timeframe Pine du niveau supérieur.
// @returns int (ms epoch)
export previousPeriodStartTime(simple string tf) =>
    request.security(syminfo.tickerid, tf, time[1], lookahead = barmerge.lookahead_on)

// @function Index de barre (`bar_index` de la TF courante) où la période précédente du timeframe
//           `tf` a commencé. Tracké via `var` à chaque transition de période détectée par
//           `timeframe.change(tf)`. Utile pour `xloc.bar_index` + extension `right`.
//           Retourne `na` tant qu'au moins deux transitions n'ont pas été observées.
// @param tf Timeframe Pine du niveau supérieur.
// @returns series int — bar_index du début de la période précédente, ou `na`.
export previousPeriodStartBar(simple string tf) =>
    var int currStart = na
    var int prevStart = na
    if timeframe.change(tf)
        prevStart := currStart
        currStart := bar_index
    prevStart

// ============================================================
// ATH (All-Time High)
// ============================================================

// Helper interne : running max du high sur la TF d'évaluation courante.
// Important : chaque site d'appel a son propre `var` (Pine sémantique), donc cette fonction est
// réutilisable depuis le contexte chart ET depuis un `request.security("D", ...)` sans collision d'état.
runningHigh() =>
    var float h = high
    if high > h
        h := high
    h

// @function Plus haut historique observable, combiné chart-courant + daily-resolution pour étendre
//           la portée temporelle au-delà des seules barres visibles dans la TF courante.
//           - `chartMax` = running max du high dans la TF courante.
//           - `dailyMax` = running max du high à la résolution daily (porte plus loin dans le temps,
//             notamment quand l'ATH date d'avant la fenêtre `max_bars_back` de la TF courante).
//           La vraie ATH = max(chartMax, dailyMax). Si l'ATH n'a pas de barre coïncidente dans la TF
//           courante, `athBarFound` = false et l'indicateur consommateur peut basculer en `extend.both`.
// @returns Tuple [athValue, athBar, athBarFound]
//          - athValue    : valeur du plus haut historique.
//          - athBar      : index de la barre où l'ATH a été atteint dans la TF courante (peut être `na`).
//          - athBarFound : `true` si l'ATH coïncide avec une barre de la TF courante.
export ath() =>
    chartMax = runningHigh()
    dailyMax = request.security(syminfo.tickerid, "D", runningHigh()[1], lookahead = barmerge.lookahead_on)
    athValue = math.max(chartMax, nz(dailyMax, chartMax))

    var int  athBar      = na
    var bool athBarFound = false
    if not na(high) and high >= athValue
        athBar      := bar_index
        athBarFound := true
    [athValue, athBar, athBarFound]

// ============================================================
// Sessions — High / Low du jour
// ============================================================

// @function H/L de la session courante. Réinitialise tout à chaque changement de date dans
//           `chartTz` (= TZ d'affichage du chart). Pendant la session, MAJ en temps réel.
//           Une fois la session terminée, la ligne reste figée jusqu'au prochain changement
//           de date chart, puis disparaît (pas de "session de la veille" visible le lendemain).
// @param sessionStr Plage horaire "HHMM-HHMM".
// @param sessionTz  Timezone IANA dans laquelle la session est définie (ex : "Asia/Tokyo").
// @param chartTz    Timezone IANA d'affichage du chart, contrôle la lifetime de la session
//                   (ex : "Europe/Paris" → reset à 00h Paris).
// @returns [sH, sL, sStartTime, sEndTime, seenToday, inSession]
export sessionHL(simple string sessionStr, simple string sessionTz, simple string chartTz) =>
    var float sH           = na
    var float sL           = na
    var int   sStart       = na
    var int   sEnd         = na
    var bool  seenToday    = false
    var bool  wasInSession = false

    // Reset à chaque changement de date chart → pas de session de la veille.
    if ta.change(dayofmonth(time, chartTz)) != 0
        sH := na
        sL := na
        sStart := na
        sEnd := na
        seenToday := false
        wasInSession := false

    inS = tm.inSession(sessionStr, sessionTz)
    if inS and not wasInSession
        sStart := time
        // Parse "HHMM-HHMM" → on connait la fin de session, on borne sEnd dès le début.
        // Pas de support cross-midnight pour l'instant (Asian/EU/US/Future ne traversent pas).
        endHH = math.round(nz(str.tonumber(str.substring(sessionStr, 5, 7)), 0))
        endMM = math.round(nz(str.tonumber(str.substring(sessionStr, 7, 9)), 0))
        sEnd  := timestamp(sessionTz, year(time, sessionTz), month(time, sessionTz), dayofmonth(time, sessionTz), endHH, endMM)
        sH := high
        sL := low
        seenToday := true
    else if inS
        sH := math.max(sH, high)
        sL := math.min(sL, low)
    wasInSession := inS

    [sH, sL, sStart, sEnd, seenToday, inS]

// ============================================================
// Opens — prix d'ouverture de session
// ============================================================

// @function Prix d'ouverture de la session pour la journée chart courante. Reset à chaque
//           changement de date dans `chartTz` (cohérent avec `sessionHL`).
// @param sessionStr "HHMM-HHMM"
// @param sessionTz  Timezone IANA dans laquelle la session est définie.
// @param chartTz    Timezone IANA d'affichage du chart (lifetime).
// @returns [openPrice, openTime, seenToday]
export sessionOpen(simple string sessionStr, simple string sessionTz, simple string chartTz) =>
    var float oPrice       = na
    var int   oTime        = na
    var bool  seenToday    = false
    var bool  wasInSession = false

    if ta.change(dayofmonth(time, chartTz)) != 0
        oPrice := na
        oTime := na
        seenToday := false
        wasInSession := false

    inS = tm.inSession(sessionStr, sessionTz)
    if inS and not wasInSession
        oPrice    := open
        oTime     := time
        seenToday := true
    wasInSession := inS

    [oPrice, oTime, seenToday]

// ============================================================
// Open Range — H/L de la première heure horaire du jour
// ============================================================

// @function H/L des 60 PREMIÈRES MINUTES de la journée (Open Range).
//           La "1re bougie du jour" = bougie où la date change vs la précédente, **dans la TZ
//           passée en argument**. Pine v6 n'expose AUCUN moyen d'accéder à la TZ d'affichage du
//           chart. `syminfo.timezone` est la TZ de l'exchange (UTC pour crypto, NY pour CFD US,
//           etc.) — différente de ce que l'utilisateur voit visuellement sur le chart. Donc on
//           exige une TZ explicite : le consommateur décide.
//
//           Tracke H/L jusqu'à `start + 60min`, puis fige. À utiliser sur les TF < H1 (M1 à M30).
// @param tz Timezone IANA (ex : "Europe/Paris") = TZ relative à laquelle "minuit" est défini.
// @returns [orH, orL, orStartTime, orEndTime, seenToday]
export openRange(simple string tz) =>
    var float orH       = na
    var float orL       = na
    var int   orStart   = na
    var int   orEnd     = na
    var bool  seenToday = false

    if ta.change(dayofmonth(time, tz)) != 0
        orStart   := time
        orEnd     := time + 3600000
        orH       := high
        orL       := low
        seenToday := true
    else if seenToday and not na(orEnd) and time < orEnd
        orH := math.max(orH, high)
        orL := math.min(orL, low)

    [orH, orL, orStart, orEnd, seenToday]
