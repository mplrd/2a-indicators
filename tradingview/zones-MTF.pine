//@version=6
// @description 2Ai Zones MTF — CMI Zones multi-timeframe (Monthly → M15).
//              Detection + validation + lookback + anti-chevauchement intra-TF
//              (Pending|Replacement) + cross-TF (Pending|Autorise) + expiration : toute la
//              logique vit dans `lib_cmi_zone`. L'indicateur ne fait que declarer les
//              inputs, appeler `cmiZone.updateAllTfs(...)` et faire le rendu via
//              `lib_draw.drawZone` avec un filtre TF-chart ≤ TF-zone (Monthly toujours).
//              Cf. SPECIFICATIONS.md § Indicateur 3.
//
// ⚠ Dependance : `lib_cmi_zone` n'est PAS encore publie sur TradingView.
//   Avant utilisation : publier `tradingview/lib-cmi-zone.pine`, puis decommenter
//   l'import + l'appel `updateAllTfs` + les appels `renderTf` ci-dessous. Mettre a
//   jour `docs/LIBS.md` avec la version assignee (cf. workflow de publication).
indicator("2Ai Zones MTF", shorttitle = "2Ai Zones MTF", overlay = true,
  max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_zone/1   as zone
// import mpilard/lib_cmi_zone/<TODO> as cmiZone  // TODO : activer apres publication TradingView
import mpilard/lib_draw/15  as draw

// ============================================================
// Inputs
// ============================================================

var globalGroup = "Global"
var mGroup      = "Monthly"
var wGroup      = "Weekly"
var dGroup      = "Daily"
var h4Group     = "H4"
var h1Group     = "H1"
var m15Group    = "M15"

// --- Global ---
intraModeStr = input.string("Pending", "Mode chevauchement intra-TF", options = ["Pending", "Replacement"], group = globalGroup, tooltip = "Pending : nouvelle zone en attente (reactivee quand le chevauchement disparait). Permet le chainage de N pending sur la meme zone de prix.\nReplacement : ancienne(s) zone(s) expiree(s), la nouvelle prend leur place.")
intraPendingMode = intraModeStr == "Pending"

crossModeStr = input.string("Pending", "Mode chevauchement cross-TF", options = ["Pending", "Autorise"], group = globalGroup, tooltip = "Pending : une zone qui chevauche une zone d'un TF superieur est mise en attente (priorite Monthly > Weekly > Daily > H4 > H1 > M15).\nAutorise : pas de regle cross-TF, les zones de differents TF peuvent se superposer.")
crossTfPending = crossModeStr == "Pending"

chartTz      = input.string("Europe/Paris", "Chart timezone", group = globalGroup, tooltip = "TZ IANA du chart. Pine ne l'expose pas, il faut la fournir pour aligner les bornes 'aujourd'hui / cette semaine / ce mois' sur l'affichage.")
lookbackBars = input.int(3, "Drawing CMI Zone Lookback", minval = 1, maxval = 5, group = globalGroup)

// --- Per TF ---
mOn      = input.bool(true,                       "Monthly",   inline = "m_h",   group = mGroup)
mColor   = input.color(color.olive,               "",          inline = "m_h",   group = mGroup)
mBordS   = input.enum(draw.LineStyle.SOLID,       "Bordure",   inline = "m_b",   group = mGroup)
mBordW   = input.int(1,                           "Epaisseur", inline = "m_b",   group = mGroup, minval = 0, maxval = 4)

wOn      = input.bool(true,                       "Weekly",    inline = "w_h",   group = wGroup)
wColor   = input.color(color.teal,                "",          inline = "w_h",   group = wGroup)
wBordS   = input.enum(draw.LineStyle.SOLID,       "Bordure",   inline = "w_b",   group = wGroup)
wBordW   = input.int(1,                           "Epaisseur", inline = "w_b",   group = wGroup, minval = 0, maxval = 4)

dOn      = input.bool(true,                       "Daily",     inline = "d_h",   group = dGroup)
dColor   = input.color(color.blue,                "",          inline = "d_h",   group = dGroup)
dBordS   = input.enum(draw.LineStyle.SOLID,       "Bordure",   inline = "d_b",   group = dGroup)
dBordW   = input.int(1,                           "Epaisseur", inline = "d_b",   group = dGroup, minval = 0, maxval = 4)

h4On     = input.bool(true,                       "H4",        inline = "h4_h",  group = h4Group)
h4Color  = input.color(color.rgb(91, 156, 246),   "",          inline = "h4_h",  group = h4Group)
h4BordS  = input.enum(draw.LineStyle.DASHED,      "Bordure",   inline = "h4_b",  group = h4Group)
h4BordW  = input.int(1,                           "Epaisseur", inline = "h4_b",  group = h4Group, minval = 0, maxval = 4)

h1On     = input.bool(false,                      "H1",        inline = "h1_h",  group = h1Group)
h1Color  = input.color(color.rgb(244, 143, 177),  "",          inline = "h1_h",  group = h1Group)
h1BordS  = input.enum(draw.LineStyle.DOTTED,      "Bordure",   inline = "h1_b",  group = h1Group)
h1BordW  = input.int(1,                           "Epaisseur", inline = "h1_b",  group = h1Group, minval = 0, maxval = 4)

m15On    = input.bool(false,                      "M15",       inline = "m15_h", group = m15Group)
m15Color = input.color(color.rgb(252, 185, 200),  "",          inline = "m15_h", group = m15Group)
m15BordS = input.enum(draw.LineStyle.DOTTED,      "Bordure",   inline = "m15_b", group = m15Group)
m15BordW = input.int(0,                           "Epaisseur", inline = "m15_b", group = m15Group, minval = 0, maxval = 4)

// ============================================================
// Orchestration MTF
// ============================================================
// Tout le travail est dans la lib : detection / validation / construction / anti-chevauchement
// (intra + cross) / expiration par periode d'interet / calcul des bornes en chartTz.
// L'indicateur recoit juste les 6 arrays prets pour le rendu.

MAX_ZONES_PER_TF = 100

// TODO (apres publication lib_cmi_zone) : decommenter le bloc suivant.
// [mZones, wZones, dZones, h4Zones, h1Zones, m15Zones] = cmiZone.updateAllTfs(
//   syminfo.tickerid, lookbackBars, intraPendingMode, crossTfPending, chartTz, MAX_ZONES_PER_TF)

// ============================================================
// Rendu
// ============================================================
// Filtre d'affichage : zone TF X visible seulement si chart TF ≤ X (Monthly toujours visible,
// quelle que soit la chart TF). Seules les zones ACTIVE sont rendues (PENDING masquees).

MONTHLY_MINUTES = 43200

var array<box>   boxArr   = array.new<box>()
var array<label> labelArr = array.new<label>()

// Signature une ligne (cf. memory pine_typing) ; `simple` preserve pour les params que
// `draw.drawZone` consomme en `simple`.
renderTf(array<zone.Zone> zones, bool on, color col, simple draw.LineStyle bStyle, simple int bWidth) =>
    if on
        chartMin = math.round(timeframe.in_seconds() / 60)
        for z in zones
            if zone.isActive(z) and (z.tfMinutes >= MONTHLY_MINUTES or chartMin <= z.tfMinutes)
                draw.drawZone(true, z, col, bWidth, bStyle, 85, 40, false, "", boxArr, labelArr)

if barstate.islast
    // Nettoyage des objets precedents.
    for bx in boxArr
        box.delete(bx)
    array.clear(boxArr)
    for lb in labelArr
        label.delete(lb)
    array.clear(labelArr)

    // TODO (apres publication lib_cmi_zone) : decommenter ces 6 appels.
    // renderTf(mZones,   mOn,   mColor,   mBordS,   mBordW)
    // renderTf(wZones,   wOn,   wColor,   wBordS,   wBordW)
    // renderTf(dZones,   dOn,   dColor,   dBordS,   dBordW)
    // renderTf(h4Zones,  h4On,  h4Color,  h4BordS,  h4BordW)
    // renderTf(h1Zones,  h1On,  h1Color,  h1BordS,  h1BordW)
    // renderTf(m15Zones, m15On, m15Color, m15BordS, m15BordW)
