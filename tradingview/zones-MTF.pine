//@version=6
// @description 2Ai Zones MTF — CMI Zones multi-timeframe (M / W / D / H4 / H1 / M15 / M5).
//              Wiring de la state machine `lib_cmi_zone` (validee en single-TF par `zones-CMI`) sur
//              7 TFs simultanees via 6 `request.security`. Anti-chevauchement intra-TF (Pending /
//              Replacement) et cross-TF (Pending / Autorise — "pas les petites si dans les grandes").
//              `lib_cmi_zone` est self-contained → rendu par `box.new` direct (pas `drawZone`).
//
//              CE10051 oblige : l'orchestration MTF vit dans l'indicateur (un `request.security`
//              dans une fonction exportee ne peut pas dependre des args de cette fonction). Les 7
//              `var array<CmiZone>` vivent donc dans le `var` interne d'`updateOne` cote lib —
//              une instance par contexte `request.security`.
indicator("2Ai Zones MTF", shorttitle = "Zones MTF", overlay = true,
  max_boxes_count = 500, max_labels_count = 500, max_lines_count = 500)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_cmi_zone/4 as cmiZone
import mpilard/lib_signal/2   as signal
import mpilard/lib_draw/16    as draw

// ============================================================
// Inputs — quadruplet [Enabled][Couleur][Bordure][Epaisseur] par TF (cohérent avec zones-CMI/SD)
// ============================================================

var mGroup   = "Monthly"
var wGroup   = "Weekly"
var dGroup   = "Daily"
var h4Group  = "H4"
var h1Group  = "H1"
var m15Group = "M15"
var m5Group  = "M5"

mEnabled  = input.bool(true,                       "Monthly", inline = "m",   group = mGroup)
mColor    = input.color(color.olive,               "",        inline = "m",   group = mGroup)
mBordS    = input.enum(draw.LineStyle.SOLID,       "",        inline = "m",   group = mGroup)
mBordW    = input.int(1,                           "",        inline = "m",   group = mGroup, minval = 0, maxval = 4)

wEnabled  = input.bool(true,                       "Weekly",  inline = "w",   group = wGroup)
wColor    = input.color(color.teal,                "",        inline = "w",   group = wGroup)
wBordS    = input.enum(draw.LineStyle.SOLID,       "",        inline = "w",   group = wGroup)
wBordW    = input.int(1,                           "",        inline = "w",   group = wGroup, minval = 0, maxval = 4)

dEnabled  = input.bool(true,                       "Daily",   inline = "d",   group = dGroup)
dColor    = input.color(color.blue,                "",        inline = "d",   group = dGroup)
dBordS    = input.enum(draw.LineStyle.SOLID,       "",        inline = "d",   group = dGroup)
dBordW    = input.int(1,                           "",        inline = "d",   group = dGroup, minval = 0, maxval = 4)

h4Enabled = input.bool(true,                       "H4",      inline = "h4",  group = h4Group)
h4Color   = input.color(color.rgb(91, 156, 246),   "",        inline = "h4",  group = h4Group)
h4BordS   = input.enum(draw.LineStyle.DASHED,      "",        inline = "h4",  group = h4Group)
h4BordW   = input.int(1,                           "",        inline = "h4",  group = h4Group, minval = 0, maxval = 4)

h1Enabled = input.bool(false,                      "H1",      inline = "h1",  group = h1Group)
h1Color   = input.color(color.rgb(244, 143, 177),  "",        inline = "h1",  group = h1Group)
h1BordS   = input.enum(draw.LineStyle.DOTTED,      "",        inline = "h1",  group = h1Group)
h1BordW   = input.int(1,                           "",        inline = "h1",  group = h1Group, minval = 0, maxval = 4)

m15Enabled = input.bool(false,                     "M15",     inline = "m15", group = m15Group)
m15Color   = input.color(color.rgb(252, 185, 200), "",        inline = "m15", group = m15Group)
m15BordS   = input.enum(draw.LineStyle.DOTTED,     "",        inline = "m15", group = m15Group)
m15BordW   = input.int(0,                          "",        inline = "m15", group = m15Group, minval = 0, maxval = 4)

m5Enabled  = input.bool(false,                     "M5",      inline = "m5",  group = m5Group)
m5Color    = input.color(color.rgb(255, 220, 230), "",        inline = "m5",  group = m5Group)
m5BordS    = input.enum(draw.LineStyle.DOTTED,     "",        inline = "m5",  group = m5Group)
m5BordW    = input.int(0,                          "",        inline = "m5",  group = m5Group, minval = 0, maxval = 4)

// === Paramètres globaux === (déclaré en dernier → affiché tout en bas de la modal TV)
var globalsGroup = "Paramètres globaux"
chartTz       = input.string("Europe/Paris", "Chart timezone", group = globalsGroup, tooltip = "TZ IANA du chart. Pine ne l'expose pas, il faut la fournir pour aligner les bornes 'aujourd'hui / cette semaine / ce mois' sur l'affichage.")
lookbackBars  = input.int(3, "Drawing CMI Zone Lookback", group = globalsGroup, minval = 1, maxval = 5)
intraModeStr  = input.string("Pending", "Mode chevauchement intra-TF", options = ["Pending", "Replacement"], group = globalsGroup, tooltip = "Pending : zone en attente si chevauchement (réactivée quand le bloqueur expire, chaînage FIFO). Replacement : l'ancienne expire, la nouvelle prend sa place.")
intraPendingMode = intraModeStr == "Pending"
crossModeStr  = input.string("Pending", "Mode chevauchement cross-TF", options = ["Pending", "Autorise"], group = globalsGroup, tooltip = "Pending : zone d'une petite UT cachée si elle chevauche une zone d'une plus grande UT (priorité M > W > D > H4 > H1 > M15 > M5). Autorise : superpositions libres.")
crossTfPending = crossModeStr == "Pending"
maxZones      = input.int(100, "Max zones par TF (FIFO)", group = globalsGroup, minval = 1, maxval = 500)

// ============================================================
// Orchestration MTF — 7 request.security (un par TF)
// ============================================================
// `interestStartForTf` mappe tfMinutes → borne d'obsolescence (depuis `computeInterestStarts`).
// M5 (tfMinutes < 15) retombe naturellement sur `subM15Start` = 1re bougie de J-1.
// Pas de `lookahead_on` : request.security retourne `array<CmiZone>` en v6, pas de shift `[1]`
// possible. La barre HTF courante peut donc flicker en temps réel — accepté, les zones se
// stabilisent après 3 bougies HTF de validation.

mZones   = request.security(syminfo.tickerid, "M",   cmiZone.updateOne(signal.detectCMI(), 43200, lookbackBars, cmiZone.interestStartForTf(43200, chartTz), maxZones))
wZones   = request.security(syminfo.tickerid, "W",   cmiZone.updateOne(signal.detectCMI(), 10080, lookbackBars, cmiZone.interestStartForTf(10080, chartTz), maxZones))
dZones   = request.security(syminfo.tickerid, "D",   cmiZone.updateOne(signal.detectCMI(), 1440,  lookbackBars, cmiZone.interestStartForTf(1440,  chartTz), maxZones))
h4Zones  = request.security(syminfo.tickerid, "240", cmiZone.updateOne(signal.detectCMI(), 240,   lookbackBars, cmiZone.interestStartForTf(240,   chartTz), maxZones))
h1Zones  = request.security(syminfo.tickerid, "60",  cmiZone.updateOne(signal.detectCMI(), 60,    lookbackBars, cmiZone.interestStartForTf(60,    chartTz), maxZones))
m15Zones = request.security(syminfo.tickerid, "15",  cmiZone.updateOne(signal.detectCMI(), 15,    lookbackBars, cmiZone.interestStartForTf(15,    chartTz), maxZones))
m5Zones  = request.security(syminfo.tickerid, "5",   cmiZone.updateOne(signal.detectCMI(), 5,     lookbackBars, cmiZone.interestStartForTf(5,     chartTz), maxZones))

// Anti-chevauchement intra-TF (idempotent — recalculé à chaque chart-bar). La passe mute en place
// le state ACTIVE/PENDING ; la lib ne retire jamais une zone non-EXPIRED, donc l'état est stable.
cmiZone.intraOverlapPass(mZones,   intraPendingMode)
cmiZone.intraOverlapPass(wZones,   intraPendingMode)
cmiZone.intraOverlapPass(dZones,   intraPendingMode)
cmiZone.intraOverlapPass(h4Zones,  intraPendingMode)
cmiZone.intraOverlapPass(h1Zones,  intraPendingMode)
cmiZone.intraOverlapPass(m15Zones, intraPendingMode)
cmiZone.intraOverlapPass(m5Zones,  intraPendingMode)

// Cross-TF descendant : pour chaque TF, downgrade ACTIVE → PENDING si chevauchement avec une zone
// non-EXPIRED d'un TF supérieur. 21 paires au total (n(n-1)/2 avec n=7). Réactivation auto au
// prochain tick si le bloqueur HTF disparaît (idempotent + intraOverlapPass remet à ACTIVE).
if crossTfPending
    cmiZone.crossTfOverlapPass(wZones,   mZones)
    cmiZone.crossTfOverlapPass(dZones,   mZones)
    cmiZone.crossTfOverlapPass(dZones,   wZones)
    cmiZone.crossTfOverlapPass(h4Zones,  mZones)
    cmiZone.crossTfOverlapPass(h4Zones,  wZones)
    cmiZone.crossTfOverlapPass(h4Zones,  dZones)
    cmiZone.crossTfOverlapPass(h1Zones,  mZones)
    cmiZone.crossTfOverlapPass(h1Zones,  wZones)
    cmiZone.crossTfOverlapPass(h1Zones,  dZones)
    cmiZone.crossTfOverlapPass(h1Zones,  h4Zones)
    cmiZone.crossTfOverlapPass(m15Zones, mZones)
    cmiZone.crossTfOverlapPass(m15Zones, wZones)
    cmiZone.crossTfOverlapPass(m15Zones, dZones)
    cmiZone.crossTfOverlapPass(m15Zones, h4Zones)
    cmiZone.crossTfOverlapPass(m15Zones, h1Zones)
    cmiZone.crossTfOverlapPass(m5Zones,  mZones)
    cmiZone.crossTfOverlapPass(m5Zones,  wZones)
    cmiZone.crossTfOverlapPass(m5Zones,  dZones)
    cmiZone.crossTfOverlapPass(m5Zones,  h4Zones)
    cmiZone.crossTfOverlapPass(m5Zones,  h1Zones)
    cmiZone.crossTfOverlapPass(m5Zones,  m15Zones)

// ============================================================
// Rendu — orchestration pure : 7 boucles inline qui délèguent à `draw.drawZoneBox` (lib_draw,
// primitive agnostique du type). On déballe les champs de CmiZone au call site et on passe le
// bool d'activité. Aucun `box.new` ni helper local.
// Filtre TF-chart ≤ TF-zone : intégré dans le param `show` (Monthly = toujours visible par spec).
// ============================================================
var array<box>   boxArr   = array.new<box>()
var array<label> labelArr = array.new<label>()  // requis par drawZoneBox (jamais peuplé, showLbl=false)

if barstate.islast
    for bx in boxArr
        box.delete(bx)
    array.clear(boxArr)

    chartMin = math.round(timeframe.in_seconds() / 60)

    for cz in mZones
        draw.drawZoneBox(mEnabled,                                cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, mColor,   mBordW,   mBordS,   85, 40, false, "", boxArr, labelArr)
    for cz in wZones
        draw.drawZoneBox(wEnabled   and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, wColor,   wBordW,   wBordS,   85, 40, false, "", boxArr, labelArr)
    for cz in dZones
        draw.drawZoneBox(dEnabled   and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, dColor,   dBordW,   dBordS,   85, 40, false, "", boxArr, labelArr)
    for cz in h4Zones
        draw.drawZoneBox(h4Enabled  and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, h4Color,  h4BordW,  h4BordS,  85, 40, false, "", boxArr, labelArr)
    for cz in h1Zones
        draw.drawZoneBox(h1Enabled  and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, h1Color,  h1BordW,  h1BordS,  85, 40, false, "", boxArr, labelArr)
    for cz in m15Zones
        draw.drawZoneBox(m15Enabled and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, m15Color, m15BordW, m15BordS, 85, 40, false, "", boxArr, labelArr)
    for cz in m5Zones
        draw.drawZoneBox(m5Enabled  and chartMin <= cz.tfMinutes, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, m5Color,  m5BordW,  m5BordS,  85, 40, false, "", boxArr, labelArr)
