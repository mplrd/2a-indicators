//@version=6
// @description 2Ai Zones — Indicateur des zones d'intérêt sur l'UT courante.
//              - Supply/Demand via CMI (sans validation 3 bougies).
//              - Fair Value Gaps (FVG) avec partial/total fill et filtre anti-faux-gap temporel.
//              - Zones 5★ : naturellement visibles dès qu'un S/D et un FVG se superposent (même side).
//              - Safe mode : filtre au rendu qui ne garde que les zones 5★.
//              Toute la logique métier (lifecycle, anti-chaînage, anti-chevauchement, detect/update,
//              cleanup) vit dans `lib_sd` et `lib_fvg`. Cet indicateur n'orchestre que les inputs,
//              l'appel des `updateZones` et le rendu.
//              Cf. SPECIFICATIONS.md § Indicateur 4.
indicator("2Ai Zones", shorttitle = "2Ai Zones", overlay = true, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_signal/2 as signal
import mpilard/lib_zone/1   as zone
import mpilard/lib_sd/1     as sd
import mpilard/lib_fvg/3    as fvg
import mpilard/lib_draw/15  as draw

// ============================================================
// Inputs
// ============================================================

var displayGroup = "Affichage"
var sdGroup      = "Supply / Demand"
var fvgGroup     = "Fair Value Gaps"

// Safe mode : si activé, n'affiche que les zones 5★ = S/D + FVG alignés en prix sur le même side.
safeMode = input.bool(false, "Safe mode (5★ uniquement)", group = displayGroup)

// --- Supply / Demand ---
sdEnabled     = input.bool(true,                   "Supply/Demand", group = sdGroup)
sdBullColor   = input.color(color.blue,            "Demand (bull)", inline = "sd_colors", group = sdGroup)
sdBearColor   = input.color(color.orange,          "Supply (bear)", inline = "sd_colors", group = sdGroup)
sdBorderStyle = input.enum(draw.LineStyle.SOLID,   "Bordure",       inline = "sd_border", group = sdGroup)
sdBorderWidth = input.int(1,                       "Épaisseur",     inline = "sd_border", group = sdGroup, minval = 0, maxval = 4)

// --- Fair Value Gaps ---
fvgEnabled     = input.bool(true,                   "FVG",       group = fvgGroup)
fvgBullColor   = input.color(color.green,           "Bullish",   inline = "fvg_colors", group = fvgGroup)
fvgBearColor   = input.color(color.red,             "Bearish",   inline = "fvg_colors", group = fvgGroup)
fvgBorderStyle = input.enum(draw.LineStyle.DASHED,  "Bordure",   inline = "fvg_border", group = fvgGroup)
fvgBorderWidth = input.int(0,                       "Épaisseur", inline = "fvg_border", group = fvgGroup, minval = 0, maxval = 4)

// ============================================================
// Orchestration : mise à jour des collections via les libs
// ============================================================

// Cap mémoire FIFO (cohérent avec max_boxes_count=500 par défaut Pine).
MAX_ZONES = 100

// Collections persistantes.
var array<zone.Zone> sdZones  = array.new<zone.Zone>()
var array<zone.Zone> fvgZones = array.new<zone.Zone>()

// Update S/D : signal CMI + lifecycle/anti-chaînage/anti-chevauchement/cleanup (tout dans lib_sd).
sd.updateZones(sdZones, signal.detectCMI(), MAX_ZONES)

// Update FVG : detect + lifecycle/cleanup (tout dans lib_fvg).
fvg.updateZones(fvgZones, MAX_ZONES)

// ============================================================
// Rendu — refresh à chaque tick sur la dernière barre
// ============================================================
var array<box>   boxArr   = array.new<box>()
var array<label> labelArr = array.new<label>()

// Helper local : vrai s'il existe dans `arr` une zone active de MÊME side qui chevauche `z` en prix.
// Sert au filtre Safe mode (zone 5★ = S/D + FVG alignés).
hasOverlappingActiveSameSide(array<zone.Zone> arr, zone.Zone z) =>
    found = false
    n = array.size(arr)
    if n > 0
        for i = 0 to n - 1
            other = array.get(arr, i)
            if zone.isActive(other) and other.side == z.side and zone.overlap(other, z)
                found := true
                break
    found

if barstate.islast
    // Nettoyage des objets précédents.
    for bx in boxArr
        box.delete(bx)
    array.clear(boxArr)
    for lb in labelArr
        label.delete(lb)
    array.clear(labelArr)

    // Rendu des zones S/D actives (transparence 85% fond / 40% bordure cf. spec).
    // CMI bull → Demand (support potentiel) ; CMI bear → Supply (résistance potentielle).
    // Safe mode : on ne dessine que si la zone a un FVG aligné (même side, chevauchement prix).
    if sdEnabled
        for z in sdZones
            keep = (not safeMode) or hasOverlappingActiveSameSide(fvgZones, z)
            if keep
                isBull = z.side == zone.ZoneSide.BULL
                col = isBull ? sdBullColor : sdBearColor
                draw.drawZone(true, z, col, sdBorderWidth, sdBorderStyle, 85, 40, false, "", boxArr, labelArr)

    // Rendu des FVG actifs. Safe mode : seulement si un S/D aligné existe.
    if fvgEnabled
        for z in fvgZones
            keep = (not safeMode) or hasOverlappingActiveSameSide(sdZones, z)
            if keep
                isBull = z.side == zone.ZoneSide.BULL
                col = isBull ? fvgBullColor : fvgBearColor
                draw.drawZone(true, z, col, fvgBorderWidth, fvgBorderStyle, 85, 40, false, "", boxArr, labelArr)
