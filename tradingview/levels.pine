//@version=6
// @description 2Ai Levels — Niveaux de prix passés (Phase 1 : ATH + niveaux de période précédente PDH/PDL, PWH/PWL, PMH/PML).
indicator("2Ai Levels", shorttitle = "2Ai Levels", overlay = true, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_levels/8 as levels
import mpilard/lib_draw/8   as draw

// ============================================================
// Inputs
// ============================================================

var levelsGroup = "Niveaux"

showLabels = input.bool(true, "Afficher les labels", inline = "labels", group = levelsGroup)

athEnabled = input.bool(true,                       "ATH", inline = "ath_level", group = levelsGroup)
athColor   = input.color(#8B0000,                   "",    inline = "ath_level", group = levelsGroup)
athStyle   = input.enum(draw.LineStyle.DASHED,      "",    inline = "ath_level", group = levelsGroup)
athWidth   = input.int(2,                           "",    inline = "ath_level", group = levelsGroup, minval = 1, maxval = 5)

dailyEnabled = input.bool(true,                     "Daily (PDH/PDL)", inline = "daily_level", group = levelsGroup)
dailyColor   = input.color(#555555,                 "",                inline = "daily_level", group = levelsGroup)
dailyStyle   = input.enum(draw.LineStyle.SOLID,     "",                inline = "daily_level", group = levelsGroup)
dailyWidth   = input.int(1,                         "",                inline = "daily_level", group = levelsGroup, minval = 1, maxval = 5)

weeklyEnabled = input.bool(true,                    "Weekly (PWH/PWL)", inline = "weekly_level", group = levelsGroup)
weeklyColor   = input.color(#555555,                "",                 inline = "weekly_level", group = levelsGroup)
weeklyStyle   = input.enum(draw.LineStyle.SOLID,    "",                 inline = "weekly_level", group = levelsGroup)
weeklyWidth   = input.int(2,                        "",                 inline = "weekly_level", group = levelsGroup, minval = 1, maxval = 5)

monthlyEnabled = input.bool(true,                   "Monthly (PMH/PML)", inline = "monthly_level", group = levelsGroup)
monthlyColor   = input.color(#555555,               "",                  inline = "monthly_level", group = levelsGroup)
monthlyStyle   = input.enum(draw.LineStyle.SOLID,   "",                  inline = "monthly_level", group = levelsGroup)
monthlyWidth   = input.int(3,                       "",                  inline = "monthly_level", group = levelsGroup, minval = 1, maxval = 5)

// --- Sessions (intraday uniquement) ---
asianEnabled = input.bool(true,                      "Session Asiatique",  inline = "asian_session",  group = levelsGroup)
asianColor   = input.color(color.orange,             "",                   inline = "asian_session",  group = levelsGroup)
asianStyle   = input.enum(draw.LineStyle.SOLID,      "",                   inline = "asian_session",  group = levelsGroup)
asianWidth   = input.int(1,                          "",                   inline = "asian_session",  group = levelsGroup, minval = 1, maxval = 5)

euEnabled = input.bool(false,                        "Session Européenne", inline = "eu_session",     group = levelsGroup)
euColor   = input.color(color.blue,                  "",                   inline = "eu_session",     group = levelsGroup)
euStyle   = input.enum(draw.LineStyle.SOLID,         "",                   inline = "eu_session",     group = levelsGroup)
euWidth   = input.int(1,                             "",                   inline = "eu_session",     group = levelsGroup, minval = 1, maxval = 5)

usEnabled = input.bool(false,                        "Session Américaine", inline = "us_session",     group = levelsGroup)
usColor   = input.color(color.purple,                "",                   inline = "us_session",     group = levelsGroup)
usStyle   = input.enum(draw.LineStyle.SOLID,         "",                   inline = "us_session",     group = levelsGroup)
usWidth   = input.int(1,                             "",                   inline = "us_session",     group = levelsGroup, minval = 1, maxval = 5)

// --- Niveaux d'ouverture ---
// Détection automatique cash / non-cash via lib_market. Les 3 Open toggles (Future/EU/US) sont
// indépendants — chacun dessine son open si la session correspondante a été observée aujourd'hui.
// IBR utilise la session cash détectée en mode cash, sinon la Future session en non-cash.
ibrEnabled = input.bool(true,                        "IBR",                inline = "ibr_level",      group = levelsGroup)
ibrColor   = input.color(#555555,                    "",                   inline = "ibr_level",      group = levelsGroup)
ibrStyle   = input.enum(draw.LineStyle.DOTTED,       "",                   inline = "ibr_level",      group = levelsGroup)
ibrWidth   = input.int(1,                            "",                   inline = "ibr_level",      group = levelsGroup, minval = 1, maxval = 5)

openFutureEnabled = input.bool(true,                  "Open Future",        inline = "open_future",    group = levelsGroup)
openFutureColor   = input.color(#555555,              "",                   inline = "open_future",    group = levelsGroup)
openFutureStyle   = input.enum(draw.LineStyle.DOTTED, "",                   inline = "open_future",    group = levelsGroup)
openFutureWidth   = input.int(1,                      "",                   inline = "open_future",    group = levelsGroup, minval = 1, maxval = 5)

openEUEnabled = input.bool(true,                      "Open EU",            inline = "open_eu",        group = levelsGroup)
openEUColor   = input.color(color.blue,               "",                   inline = "open_eu",        group = levelsGroup)
openEUStyle   = input.enum(draw.LineStyle.DOTTED,     "",                   inline = "open_eu",        group = levelsGroup)
openEUWidth   = input.int(1,                          "",                   inline = "open_eu",        group = levelsGroup, minval = 1, maxval = 5)

openUSEnabled = input.bool(true,                      "Open US",            inline = "open_us",        group = levelsGroup)
openUSColor   = input.color(color.purple,             "",                   inline = "open_us",        group = levelsGroup)
openUSStyle   = input.enum(draw.LineStyle.DOTTED,     "",                   inline = "open_us",        group = levelsGroup)
openUSWidth   = input.int(1,                          "",                   inline = "open_us",        group = levelsGroup, minval = 1, maxval = 5)

// --- Paramètres des Sessions ---
var sessionParamsGroup = "Paramètres des Sessions"
asianSessionStr  = input.session("0800-1400",     "Asiatique",  inline = "asian_params",  group = sessionParamsGroup)
asianTz          = input.string("Asia/Tokyo",     "",           inline = "asian_params",  group = sessionParamsGroup)
euSessionStr     = input.session("0900-1400",     "Européenne", inline = "eu_params",     group = sessionParamsGroup)
euTz             = input.string("Europe/Paris",   "",           inline = "eu_params",     group = sessionParamsGroup)
usSessionStr     = input.session("0930-1600",     "Américaine", inline = "us_params",     group = sessionParamsGroup)
usTz             = input.string("America/New_York","",          inline = "us_params",     group = sessionParamsGroup)
futureSessionStr = input.session("0800-0900",     "Future open",inline = "future_params", group = sessionParamsGroup)
futureTz         = input.string("Europe/Paris",   "",           inline = "future_params", group = sessionParamsGroup)

// ============================================================
// Filtres TF d'affichage
// Règle : un niveau d'une période donnée s'affiche uniquement si la TF courante est <= à cette période.
// Sessions : intraday uniquement (timeframe.isintraday).
// ============================================================
tfSec       = timeframe.in_seconds()
showDaily   = tfSec <= timeframe.in_seconds("D")
showWeekly  = tfSec <= timeframe.in_seconds("W")
showMonthly = tfSec <= timeframe.in_seconds("M")
showIntraday = timeframe.isintraday

// ============================================================
// Calculs des niveaux
// ============================================================
[pdH, pdL] = levels.previousPeriodHL("D")
[pwH, pwL] = levels.previousPeriodHL("W")
[pmH, pmL] = levels.previousPeriodHL("M")

pdStartBar = levels.previousPeriodStartBar("D")
pwStartBar = levels.previousPeriodStartBar("W")
pmStartBar = levels.previousPeriodStartBar("M")

[athValue, athBar, athBarFound] = levels.ath()

// Sessions H/L (calculées en permanence — Pine les exige tick-by-tick).
[asianH, asianL, asianStart, asianSeen] = levels.sessionHL(asianSessionStr, asianTz)
[euH,    euL,    euStart,    euSeen]    = levels.sessionHL(euSessionStr,    euTz)
[usH,    usL,    usStart,    usSeen]    = levels.sessionHL(usSessionStr,    usTz)

// Opens & IBR par session (calculés en permanence, sélectionnés au rendu).
[asianOpen,  asianOpenTime,  asianOpenSeen]  = levels.sessionOpen(asianSessionStr,  asianTz)
[euOpen,     euOpenTime,     euOpenSeen]     = levels.sessionOpen(euSessionStr,     euTz)
[usOpen,     usOpenTime,     usOpenSeen]     = levels.sessionOpen(usSessionStr,     usTz)
[futureOpen, futureOpenTime, futureOpenSeen] = levels.sessionOpen(futureSessionStr, futureTz)

// IBR : 1re bougie horaire du jour (dans la TZ naturelle de l'instrument).
// Règle : la barre où la date change vs la barre précédente est la 1re du jour. C'est tout.
// Wrap `request.security` sur M1 pour couvrir exactement 60min depuis cette 1re barre, quel que soit le TF.
[ibrH, ibrL, ibrStart, _ibrSeen] = request.security(syminfo.tickerid, "1", levels.firstH1OfDay())

// ============================================================
// Rendu — refresh à chaque tick sur la dernière barre
// Dessin délégué à `draw.drawLevel()` (Couche 2). L'indicateur n'orchestre que.
// ============================================================
var array<line>  lineArr  = array.new<line>()
var array<label> labelArr = array.new<label>()

if barstate.islast
    // Nettoyage des objets précédents
    for ln in lineArr
        line.delete(ln)
    array.clear(lineArr)
    for lb in labelArr
        label.delete(lb)
    array.clear(labelArr)

    // ATH (toujours TF-allowed)
    draw.drawLevel(athEnabled, athValue, athBar, athBarFound, athColor, athWidth, athStyle, "ATH", showLabels, lineArr, labelArr)

    // PDH / PDL
    draw.drawLevel(dailyEnabled and showDaily, pdH, pdStartBar, not na(pdStartBar), dailyColor, dailyWidth, dailyStyle, "PDH", showLabels, lineArr, labelArr)
    draw.drawLevel(dailyEnabled and showDaily, pdL, pdStartBar, not na(pdStartBar), dailyColor, dailyWidth, dailyStyle, "PDL", showLabels, lineArr, labelArr)

    // PWH / PWL
    draw.drawLevel(weeklyEnabled and showWeekly, pwH, pwStartBar, not na(pwStartBar), weeklyColor, weeklyWidth, weeklyStyle, "PWH", showLabels, lineArr, labelArr)
    draw.drawLevel(weeklyEnabled and showWeekly, pwL, pwStartBar, not na(pwStartBar), weeklyColor, weeklyWidth, weeklyStyle, "PWL", showLabels, lineArr, labelArr)

    // PMH / PML
    draw.drawLevel(monthlyEnabled and showMonthly, pmH, pmStartBar, not na(pmStartBar), monthlyColor, monthlyWidth, monthlyStyle, "PMH", showLabels, lineArr, labelArr)
    draw.drawLevel(monthlyEnabled and showMonthly, pmL, pmStartBar, not na(pmStartBar), monthlyColor, monthlyWidth, monthlyStyle, "PML", showLabels, lineArr, labelArr)

    // Sessions H/L (intraday uniquement)
    draw.drawSessionLevel(asianEnabled and showIntraday and asianSeen, asianH, asianStart, asianColor, asianWidth, asianStyle, "Asian H", showLabels, lineArr, labelArr)
    draw.drawSessionLevel(asianEnabled and showIntraday and asianSeen, asianL, asianStart, asianColor, asianWidth, asianStyle, "Asian L", showLabels, lineArr, labelArr)
    draw.drawSessionLevel(euEnabled    and showIntraday and euSeen,    euH,    euStart,    euColor,    euWidth,    euStyle,    "EU H",    showLabels, lineArr, labelArr)
    draw.drawSessionLevel(euEnabled    and showIntraday and euSeen,    euL,    euStart,    euColor,    euWidth,    euStyle,    "EU L",    showLabels, lineArr, labelArr)
    draw.drawSessionLevel(usEnabled    and showIntraday and usSeen,    usH,    usStart,    usColor,    usWidth,    usStyle,    "US H",    showLabels, lineArr, labelArr)
    draw.drawSessionLevel(usEnabled    and showIntraday and usSeen,    usL,    usStart,    usColor,    usWidth,    usStyle,    "US L",    showLabels, lineArr, labelArr)

    // Opens : 3 toggles indépendants du mode cash/non-cash. En cash mode, le bon Open XX
    // affiche de facto l'OPR Open de la session détectée.
    draw.drawSessionLevel(openFutureEnabled and showIntraday and futureOpenSeen, futureOpen, futureOpenTime, openFutureColor, openFutureWidth, openFutureStyle, "Open Future", showLabels, lineArr, labelArr)
    draw.drawSessionLevel(openEUEnabled     and showIntraday and euOpenSeen,     euOpen,     euOpenTime,     openEUColor,     openEUWidth,     openEUStyle,     "Open EU",     showLabels, lineArr, labelArr)
    draw.drawSessionLevel(openUSEnabled     and showIntraday and usOpenSeen,     usOpen,     usOpenTime,     openUSColor,     openUSWidth,     openUSStyle,     "Open US",     showLabels, lineArr, labelArr)

    // IBR : selection auto cash (session détectée) / non-cash (Future).
    draw.drawSessionLevel(ibrEnabled and showIntraday, ibrH, ibrStart, ibrColor, ibrWidth, ibrStyle, "IBR H", showLabels, lineArr, labelArr)
    draw.drawSessionLevel(ibrEnabled and showIntraday, ibrL, ibrStart, ibrColor, ibrWidth, ibrStyle, "IBR L", showLabels, lineArr, labelArr)
