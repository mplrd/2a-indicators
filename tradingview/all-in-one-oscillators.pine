//@version=6
// @description 2Ai All-In-One Oscillators — version "tout-en-un" du 2e volet pour compte TradingView
//              gratuit (limité en nombre d'indicateurs). Regroupe MACD ZR + Divergences (RSI &
//              Stochastic RSI) dans UN seul script. Aucune logique dupliquée : tout vient des libs
//              (lib_macd, lib_rsi, lib_stochrsi, lib_divergence). Défauts alignés sur le périmètre
//              choisi (RSI + MA + divergences + divergences cachées, Stoch + divergences, niveaux).
//              NB : un seul volet possible en gratuit. MACD affiché SEUL → échelle "prix" réelle ;
//              dès que RSI ou Stoch est aussi affiché, le MACD est rebasé dans la bande 0-100 (0 → 50)
//              pour cohabiter avec eux (softsign borné, échelle = volatilité récente).
indicator(title = "All-In-One Oscillators", shorttitle = "AIO Oscillators", overlay = false)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_ma/4         as ma
import mpilard/lib_macd/2       as macd
import mpilard/lib_rsi/1        as rsi
import mpilard/lib_stochrsi/1   as stochrsi
import mpilard/lib_divergence/1 as divergence

// ============================================================
// Inputs — MACD ZR
// ============================================================
var grpMacd  = "MACD ZR"
macdShow     = input.bool(true,           "Display",       group = grpMacd)
src          = input.source(close,        "Source",        group = grpMacd)
fastLength   = input.int(12,              "Fast length",   group = grpMacd, minval = 1)
slowLength   = input.int(26,              "Slow length",   group = grpMacd, minval = 1)
signalLength = input.int(9,               "Signal length", group = grpMacd, minval = 1)
maMode       = input.enum(ma.MaMode.DEMA, "Méthode de lissage", group = grpMacd, tooltip = "DEMA : lisse, lag réduit (parité v5 de référence). TEMA : compromis lag/lissage. ZLEMA : très réactif, plus bruité.")

// ============================================================
// Inputs — Divergences (RSI + Stochastic RSI)
// ============================================================
var grpIndic = "RSI / Stochastic"
indicLength = input.int(14, title = "Length (RSI & Stoch)", group = grpIndic, tooltip = "Longueur commune au RSI et au Stochastic RSI. Le MACD a ses propres longueurs (groupe MACD ZR).")

var grpRsi = "RSI Settings"
rsiShow          = input.bool(true,  "Display",                  group = grpRsi, inline = "rsi")
rsiShowMa        = input.bool(true,  "With MA",                  group = grpRsi, inline = "rsi")
rsiMaLength      = input.int(50,     "",                         group = grpRsi, inline = "rsi")
rsiShowDiv       = input.bool(true,  "With divergences",         group = grpRsi, inline = "rsiDiv")
rsiShowHiddenDiv = input.bool(true,  "With hidden divergences",  group = grpRsi, inline = "rsiDiv")

var grpStoch = "Stochastic Settings"
stochShow          = input.bool(true, "Display",                 group = grpStoch)
stochShowDiv       = input.bool(true, "With divergences",        group = grpStoch, inline = "stochDiv")
stochShowHiddenDiv = input.bool(true, "With hidden divergences", group = grpStoch, inline = "stochDiv")

var grpLevels = "Levels"
levelDisplay     = input.bool(true, "Display",              group = grpLevels)
levelOversold1   = input.int(38,    "Oversold",             group = grpLevels, inline = "Oversold")
levelOversold2   = input.int(25,    "Extremely Oversold",   group = grpLevels, inline = "Oversold")
levelOverbought1 = input.int(62,    "Overbought",           group = grpLevels, inline = "Overbought")
levelOverbought2 = input.int(75,    "Extremely Overbought", group = grpLevels, inline = "Overbought")

// ============================================================
// Constantes
// ============================================================
indicatorSource = close
SMOOTH = 3
MEDIAN = 50

// ============================================================
// Calculs — MACD ZR (délégué à lib_macd)
// ============================================================
[macdLine, signalLine, hist, average] = macd.zeroLag(src, fastLength, slowLength, signalLength, maMode)

// Rebase d'échelle conditionnel : le MACD vit sur l'échelle "prix", incompatible avec le 0-100 du
// RSI/Stoch. MACD SEUL (RSI et Stoch off) → valeurs brutes conservées ; dès qu'un des deux 0-100 est
// aussi affiché, on rebase le MACD dans la bande 0-100 (0 → 50) via un softsign borné (Pine n'a pas
// math.tanh). Échelle = volatilité récente du MACD (adaptatif, pas de constante magique par instrument).
macdAlone = not rsiShow and not stochShow
kMacd = ta.stdev(macdLine, 100)
kHist = ta.stdev(hist, 100)
softTo100(float x, float k) =>
    r = k != 0 ? x / (2.0 * k) : 0.0
    50.0 + 50.0 * (r / (1.0 + math.abs(r)))
macdV = macdAlone ? macdLine   : softTo100(macdLine,   kMacd)
sigV  = macdAlone ? signalLine : softTo100(signalLine, kMacd)
avgV  = macdAlone ? average    : softTo100(average,    kMacd)

// ============================================================
// Calculs — Divergences (délégués aux libs)
// ============================================================
rsiValue = rsi.compute(indicatorSource, indicLength)
rsiMA    = rsi.movingAverage(rsiValue, rsiMaLength)

[stochK, stochD] = stochrsi.compute(indicatorSource, indicLength, indicLength, SMOOTH, SMOOTH, false, false)

// 2 passes RSI : avec bornes OB/OS (divergences classiques) + sans bornes (détection libre).
[rsiFractalTop,   rsiFractalBot,   rsiBearReg,   rsiBullReg,   rsiBearHid,   rsiBullHid]   = divergence.findDivergences(rsiValue, high, low, levelOverbought1, levelOversold1, true)
[rsiFractalTopNl, rsiFractalBotNl, rsiBearRegNl, rsiBullRegNl, rsiBearHidNl, rsiBullHidNl] = divergence.findDivergences(rsiValue, high, low, 0, 0, false)

// Stoch RSI : pas de bornes (oscille déjà 0-100).
[stochFractalTop, stochFractalBot, stochBearReg, stochBullReg, stochBearHid, stochBullHid] = divergence.findDivergences(stochK, high, low, 0, 0, false)

// ============================================================
// Couleurs — état RSI (overbought / oversold) et divergences
// ============================================================
rsiColor = color.gray
if rsiValue < levelOversold2 and rsiValue[1] <= levelOversold2
    rsiColor := color.green
else if rsiValue < levelOversold1 and rsiValue[1] <= levelOversold1
    rsiColor := color.green
else if rsiValue > levelOverbought2 and rsiValue[1] >= levelOverbought2
    rsiColor := color.red
else if rsiValue > levelOverbought1 and rsiValue[1] >= levelOverbought1
    rsiColor := color.red

rsiBearDivColor = (rsiShowDiv and rsiBearReg) or (rsiShowHiddenDiv and rsiBearHid) ? color.rgb(170, 0, 0, 0) : na
rsiBullDivColor = (rsiShowDiv and rsiBullReg) or (rsiShowHiddenDiv and rsiBullHid) ? color.rgb(0, 100, 3, 0) : na

stochBearDivColor = (stochShowDiv and stochBearReg) or (stochShowHiddenDiv and stochBearHid) ? color.rgb(255, 53, 53, 40) : na
stochBullDivColor = (stochShowDiv and stochBullReg) or (stochShowHiddenDiv and stochBullHid) ? color.rgb(68, 184, 71, 40) : na

// ============================================================
// Rendu — MACD ZR
// ============================================================
macdMainColor = hist > 0 ? color.rgb(76, 175, 79) : color.rgb(255, 82, 82)
macdDisplay   = macdShow ? display.all : display.none

// Histogramme : colonnes depuis 0 quand le MACD est seul ; sinon (rebasé 0-100) les colonnes Pine
// partent toujours de 0 → inexploitable dans la bande → on rend une "aire" centrée sur 50 via fill.
plot(macdAlone ? hist : na, title = "Histogram", style = plot.style_columns, color = macdMainColor, display = macdDisplay)
hMid = plot(macdAlone ? na : 50.0,                   title = "Hist base 50", color = na, display = display.none, editable = false)
hTop = plot(macdAlone ? na : softTo100(hist, kHist), title = "Hist top",     color = na, display = display.none, editable = false)
fill(hMid, hTop, title = "Histogram (rebasé)", color = macdMainColor, display = macdDisplay)

pSignal = plot(sigV, title = "Signal",  color = macdMainColor, linewidth = 1, display = macdDisplay)
pMacd   = plot(macdV, title = "MACD ZR", color = color.gray, display = macdDisplay)
fill(pMacd, pSignal, title = "MACD Background", color = hist > 0 ? color.rgb(76, 175, 79, 50) : color.rgb(255, 82, 82, 75), display = macdDisplay)
plot(avgV, title = "MA Line", color = color.rgb(82, 122, 255), display = macdDisplay)

// ============================================================
// Rendu — Niveaux RSI (hlines)
// ============================================================
hline(MEDIAN,           title = "Median",             color = color.new(color.blue,  5), linestyle = hline.style_dotted, linewidth = 1, display = levelDisplay              ? display.all : display.none)
hline(levelOverbought1, title = "Overbought level 1", color = color.new(color.red,   5), linestyle = hline.style_dotted, linewidth = 1, display = levelDisplay and rsiShow ? display.all : display.none)
hline(levelOverbought2, title = "Overbought level 2", color = color.new(color.red,   5), linestyle = hline.style_dashed, linewidth = 1, display = levelDisplay and rsiShow ? display.all : display.none)
hline(levelOversold1,   title = "Oversold level 1",   color = color.new(color.green, 5), linestyle = hline.style_dotted, linewidth = 1, display = levelDisplay and rsiShow ? display.all : display.none)
hline(levelOversold2,   title = "Oversold level 2",   color = color.new(color.green, 5), linestyle = hline.style_dashed, linewidth = 1, display = levelDisplay and rsiShow ? display.all : display.none)

// ============================================================
// Rendu — RSI + divergences + MA + gradient fill OB/OS
// ============================================================
rsiplot = plot(rsiShow ? rsiValue : na, title = "RSI", color = rsiColor, linewidth = 2, display = rsiShow ? display.all : display.none)
plot(series = rsiFractalTop ? rsiValue[2] : na, title = "RSI Bearish Divergence", color = rsiBearDivColor, linewidth = 3, offset = -2, display = rsiShow ? display.all : display.none)
plot(series = rsiFractalBot ? rsiValue[2] : na, title = "RSI Bullish Divergence", color = rsiBullDivColor, linewidth = 3, offset = -2, display = rsiShow ? display.all : display.none)
plot(series = rsiMA, title = "RSI MA", color = color.blue, display = rsiShow and rsiShowMa ? display.all : display.none)

midLinePlot = plot(MEDIAN, color = na, editable = false, display = display.none)
fill(rsiplot, midLinePlot, 100,            levelOverbought1, top_color = color.new(color.red,   0),   bottom_color = color.new(color.red,   100), title = "Overbought Gradient Fill")
fill(rsiplot, midLinePlot, levelOversold1, 0,                top_color = color.new(color.green, 100), bottom_color = color.new(color.green, 0),   title = "Oversold Gradient Fill")

// ============================================================
// Rendu — Stochastic RSI + divergences + fill K/D
// ============================================================
stochKplot = plot(stochShow ? stochK : na, title = "Stoch K", color = color.rgb(33,  187, 243, 40), linewidth = 1, display = stochShow ? display.all : display.none)
stochDplot = plot(stochShow ? stochD : na, title = "Stoch D", color = color.rgb(103, 58,  183, 60), linewidth = 1, display = stochShow ? display.all : display.none)
stochFillColor = stochK >= stochD ? color.rgb(33, 186, 243, 80) : color.rgb(103, 58, 183, 70)
fill(stochKplot, stochDplot, title = "KD Fill", color = stochFillColor)

plot(series = stochFractalTop ? stochK[2] : na, title = "Stoch Bearish Divergence", color = stochBearDivColor, linewidth = 1, offset = -2, display = stochShow ? display.all : display.none)
plot(series = stochFractalBot ? stochK[2] : na, title = "Stoch Bullish Divergence", color = stochBullDivColor, linewidth = 1, offset = -2, display = stochShow ? display.all : display.none)
