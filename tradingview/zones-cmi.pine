//@version=6
// @description 2Ai CMI Zones (test single-TF) — valide la state machine de `lib_cmi_zone` sur l'UT
//              du chart : detection CMI (lib_signal) + validation 3 bougies + construction par
//              lookback + anti-chevauchement intra-TF (Pending|Replacement). PAS de MTF ni de
//              `request.security` ici (on isole le cœur logique avant de wirer `zones-MTF.pine`).
//              `interestStartTime = 0` → pas d'expiration par periode d'interet (borne FIFO `maxZones`).
indicator("2Ai CMI Zones", shorttitle = "Zones CMI", overlay = true, max_boxes_count = 500, max_labels_count = 500)

// ============================================================
// Imports
// ============================================================
import mpilard/lib_cmi_zone/4 as cmiZone
import mpilard/lib_signal/2   as signal
import mpilard/lib_draw/17    as draw

// ============================================================
// Inputs
// ============================================================
var grp = "Zones CMI"

// Triplet inline [Enabled] [Couleur] [Bordure] [Épaisseur] (pattern levels.pine).
cmiEnabled = input.bool(true,                    "Zones",     inline = "z", group = grp)
zoneColor  = input.color(color.teal,             "",          inline = "z", group = grp)
bordStyle  = input.enum(draw.LineStyle.SOLID,    "",          inline = "z", group = grp)
bordWidth  = input.int(1,                        "",          inline = "z", group = grp, minval = 0, maxval = 4)

// === Paramètres globaux === (déclaré en dernier → affiché tout en bas de la modal TV)
var globalsGroup = "Paramètres globaux"
lookbackBars = input.int(3,         "Drawing CMI Zone Lookback",  group = globalsGroup, minval = 1, maxval = 5)
intraModeStr = input.string("Pending", "Mode chevauchement intra-TF", options = ["Pending", "Replacement"], group = globalsGroup, tooltip = "Pending : zone en attente si chevauchement (reactivee quand le blocker expire). Replacement : l'ancienne zone expire, la nouvelle prend sa place.")
pendingMode  = intraModeStr == "Pending"
maxZones     = input.int(100,       "Max zones (FIFO)",           group = globalsGroup, minval = 1, maxval = 500)

// ============================================================
// State machine sur l'UT du chart
// ============================================================
// Pine n'expose pas la TZ d'affichage du chart → hardcodee (cf. lib_levels). Sert au calcul des
// bornes d'interet ("aujourd'hui", "ce lundi"...) cote lib.
chartTz = "Europe/Paris"
tfMin   = int(timeframe.in_seconds() / 60)

// Obsolescence : la lib renvoie la borne d'interet pour l'UT du chart ; les zones plus anciennes
// expirent (au lieu de `0` = illimite). C'est la lib qui porte cette regle metier.
interestStart = cmiZone.interestStartForTf(tfMin, chartTz)
zones = cmiZone.updateOne(signal.detectCMI(), tfMin, lookbackBars, interestStart, maxZones)
cmiZone.intraOverlapPass(zones, pendingMode)

// ============================================================
// Rendu — orchestration pure : itération + appel de `draw.drawZoneBox` (lib_draw, primitive
// agnostique du type UDT). On déballe les champs de `CmiZone` au call site et on passe le bool
// d'activité (`cz.state == ACTIVE`). Aucun `box.new` inline, aucun helper local.
// ============================================================
var array<box>   boxArr   = array.new<box>()
var array<label> labelArr = array.new<label>()  // requis par la signature drawZoneBox (jamais peuplé ici, showLbl=false)

if barstate.islast
    draw.clearBoxes(boxArr)
    for cz in zones
        draw.drawZoneBox(cmiEnabled, cz.state == cmiZone.CmiState.ACTIVE, cz.leftTime, cz.top, cz.bottom, zoneColor, bordWidth, bordStyle, 85, 40, false, "", boxArr, labelArr)
