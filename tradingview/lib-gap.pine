//@version=6
// @description lib-gap — détection de gaps journaliers + statut de comblement. Couche 1. Pas de dessin.
//              Porté de l'ancien indicateur (logique validée). La détection s'exécute sur la barre
//              DAILY (`low`/`high` vs clôture précédente) ; le consommateur l'appelle via
//              `request.security(ticker, "D", detectDaily())` pour afficher les gaps daily sur
//              n'importe quel timeframe, et crée/met à jour la box lui-même (les libs ne dessinent pas).
library("lib_gap", overlay = true)

// ============================================================
// Détection (contexte daily, via request.security(ticker, "D", ...))
// ============================================================

// @function Détecte un gap journalier sur la barre daily courante.
//           - Haussier : `low > close[1]`  → zone [close[1], low], direction `1`.
//           - Baissier : `high < close[1]` → zone [high, close[1]], direction `-1`.
//           Ne détecte qu'en `timeframe.isdaily` (sinon aucun gap). La mèche de la barre daily inclut
//           TOUT le trading du jour, donc `low > close[1]` traduit un vrai gap non comblé — pas de
//           faux gap sur les instruments 24h (le mouvement nocturne est dans la barre daily, pas un gap),
//           contrairement à une détection au minuit-chart.
// @returns [hasGap (bool), top (float), bottom (float), direction (int : 1 haussier / -1 baissier / 0 aucun)]
export detectDaily() =>
    bool  hasGap = false
    float top    = na
    float bottom = na
    int   dir    = 0
    if timeframe.isdaily
        if low > close[1]
            hasGap := true
            top    := low
            bottom := close[1]
            dir    := 1
        else if high < close[1]
            hasGap := true
            top    := close[1]
            bottom := high
            dir    := -1
    [hasGap, top, bottom, dir]

// ============================================================
// Comblement (contexte du chart)
// ============================================================

// @function Statut de comblement d'un gap avec la barre courante (timeframe du chart).
//           - Haussier (`dir = 1`) : comblement partiel si le prix entre dans la zone
//             (`low <= top and low > bottom`) → `newTop = low` ; total si `low <= bottom`.
//           - Baissier (`dir = -1`) : partiel si `high >= bottom and high < top` → `newBottom = high` ;
//             total si `high >= top`.
//           Le consommateur applique `box.set_top`/`set_bottom` (partiel) ou `box.delete` (total).
// @param top        Bord supérieur courant du gap.
// @param bottom     Bord inférieur courant du gap.
// @param direction  `1` (haussier) ou `-1` (baissier).
// @returns [isFilled (bool), isPartial (bool), newTop (float), newBottom (float)]
export checkFill(float top, float bottom, int direction) =>
    bool  isFilled  = false
    bool  isPartial = false
    float newTop    = top
    float newBottom = bottom
    if direction == 1
        if low <= top and low > bottom
            isPartial := true
            newTop    := low
        if low <= bottom
            isFilled := true
    else if direction == -1
        if high >= bottom and high < top
            isPartial := true
            newBottom := high
        if high >= top
            isFilled := true
    [isFilled, isPartial, newTop, newBottom]
