//@version=6
// @description lib-cmi-zone — CMI Zones lifecycle (Couche 1). Pas de dessin.
//              Detection (delegue a lib_signal), validation 3 bougies (bougies 1/2/3, cassure de
//              l'EXTREME `low`/`high` de la CMI — pas de l'open ; une CMI opposee n'invalide PAS la
//              precedente, validations PARALLELES via une queue de pendings), construction par
//              lookback sur le CORPS (pas la cloture), anti-chevauchement intra-TF
//              (Pending|Replacement) declenche par open-de-la-CMI-dans-zone OU chevauchement
//              geometrique, cross-TF par chevauchement, expiration par periode d'interet, FIFO.
//
//              UDT `CmiZone` **self-contained** (champs a plat, pas de wrap de `zone.Zone` de
//              `lib_zone`) : Pine v6 ne resout pas correctement les enums cross-lib quand un UDT
//              en wrap un autre (CE10263/CE10293). La lib reimplemente donc ses propres helpers
//              (overlap, state mutations) sur ses propres champs et n'importe pas `lib_zone`.
//
//              API publique (helpers ; orchestration MTF dans `zones-MTF.pine` cote indicateur,
//              CE10051 interdit les `request.security` dependant des args d'une fonction exportee) :
//                - Enums `CmiSide`, `CmiState` + UDT `CmiZone`.
//                - `updateOne(...)` → `array<CmiZone>` single-TF (zones brutes ACTIVE).
//                - `intraOverlapPass(zones, pendingMode)` : pending si open-de-la-CMI dans une
//                  zone vivante OU si les zones reconstruites se chevauchent.
//                - `crossTfOverlapPass(lower, higher)` : downgrade ACTIVE → PENDING par
//                  chevauchement avec TF superieur.
//                - `computeInterestStarts(chartTz)` → 7 bornes (M, W, D, H4, H1, M15, < M15).
//                - `interestStartForTf(tfMinutes, chartTz)` → borne d'obsolescence d'UN TF.
//              Cf. SPECIFICATIONS.md § Indicateur 3.
library("lib_cmi_zone", overlay = true)

import mpilard/lib_signal/2 as signal

// ============================================================
// Enums + UDTs
// ============================================================

// @enum CmiSide — sens de la CMI a l'origine de la zone.
export enum CmiSide
    BULL
    BEAR

// @enum CmiState — etat de cycle de vie de la zone.
export enum CmiState
    ACTIVE
    PENDING
    EXPIRED

// @type CmiZone — zone de prix construite a partir d'une CMI validee. Champs self-contained.
//        `cmiOpen` est conserve pour le declencheur Pending : si une nouvelle CMI a son open dans
//        une zone existante (independamment du chevauchement geometrique de la zone reconstruite),
//        elle passe en pending.
export type CmiZone
    float    top
    float    bottom
    int      leftTime
    CmiSide  side
    CmiState state
    int      tfMinutes
    float    cmiOpen

// @type (interne) PendingCMI — CMI detectee, en cours de validation 3 bougies. Plusieurs peuvent
//        co-exister (validations paralleles : une CMI opposee n'invalide pas la precedente).
type PendingCMI
    int     barIndex
    int     barsLeft
    CmiSide side
    float   open
    float   low
    float   high

// ============================================================
// Helpers prives
// ============================================================

// @function (privé) Chevauchement geometrique en prix entre deux zones.
overlap(CmiZone a, CmiZone b) =>
    not (a.top < b.bottom or a.bottom > b.top)

// @function (privé) Retire les CmiZone EXPIRED. Iteration descendante avec garde size > 0
//           (Pine : `for i = -1 to 0` itererait ascendant et lirait array.get(-1) → erreur).
removeExpiredCmi(array<CmiZone> cz) =>
    if array.size(cz) > 0
        for i = array.size(cz) - 1 to 0
            if array.get(cz, i).state == CmiState.EXPIRED
                array.remove(cz, i)

// @function (privé) FIFO : retire les plus anciennes si > maxCount.
trimOldestCmi(array<CmiZone> cz, simple int maxCount) =>
    while array.size(cz) > maxCount
        array.shift(cz)

// @function (privé) Construit la CmiZone d'une PendingCMI venant juste de valider (corps + extremes
//           du lookback). Retourne `na` si lookbackBars <= 0.
constructZoneFromPending(PendingCMI p, int lookbackBars, int tfMinutes) =>
    CmiZone result = na
    if lookbackBars > 0
        int   offCMI      = bar_index - p.barIndex
        float topPrice    = na
        float bottomPrice = na
        int   topTime     = na
        int   bottomTime  = na
        for k = 0 to lookbackBars - 1
            int   off = offCMI + k
            float o   = open[off]
            float c   = close[off]
            float h   = high[off]
            float l   = low[off]
            int   t   = time[off]
            if p.side == CmiSide.BULL
                float bodyLow = math.min(o, c)
                if na(topPrice) or bodyLow < topPrice
                    topPrice := bodyLow
                    topTime  := t
                if na(bottomPrice) or l < bottomPrice
                    bottomPrice := l
                    bottomTime  := t
            else
                if na(topPrice) or h > topPrice
                    topPrice := h
                    topTime  := t
                float bodyHigh = math.max(o, c)
                if na(bottomPrice) or bodyHigh > bottomPrice
                    bottomPrice := bodyHigh
                    bottomTime  := t
        int leftT = math.min(topTime, bottomTime)
        result := CmiZone.new(topPrice, bottomPrice, leftT, p.side, CmiState.ACTIVE, tfMinutes, p.open)
    result

// ============================================================
// State machine per-TF (validations paralleles)
// ============================================================

// @function State machine d'une seule TF : detection + validation 3 bougies (en parallele —
//           plusieurs CMIs peuvent etre en cours en meme temps) + construction par lookback sur
//           le corps + expiration par periode d'interet + cleanup. **PAS** d'anti-chevauchement
//           (le consommateur appelle `intraOverlapPass` / `crossTfOverlapPass` apres).
//           Validation : CMI = bougie 0 ; bougies 1, 2 et 3. Invalidee uniquement si une cloture
//           passe **sous le `low`** (haussiere) ou **au-dessus du `high`** (baissiere) de la CMI.
//           Une CMI opposee n'invalide PAS — chaque CMI valide independamment, plusieurs zones
//           peuvent coexister (range typique).
//           Construction : bull → Top = plus bas `min(open,close)`, Bottom = plus bas `low`.
//           Bear → Top = plus haut `high`, Bottom = plus haut `max(open,close)`.
//           Collection en `var` interne au site d'appel : en MTF, chaque `request.security` cote
//           indicateur a son state isole.
// @param cmiSignal          Sortie de `signal.detectCMI()` dans le contexte serie appelant.
// @param tfMinutes          Timeframe d'origine en minutes (stocke dans la zone).
// @param lookbackBars       Nombre de bougies de la fenetre de construction (1-5).
// @param interestStartTime  Timestamp ms en deca duquel les zones expirent (0 = illimite).
// @param maxZones           Cap FIFO interne.
// @returns array<CmiZone> (var interne au site d'appel).
export updateOne(signal.SignalKind cmiSignal, int tfMinutes, int lookbackBars,
  int interestStartTime, simple int maxZones) =>

    var array<CmiZone>    zones   = array.new<CmiZone>()
    var array<PendingCMI> pending = array.new<PendingCMI>()

    // --- 1. Expiration par periode d'interet ---
    n0 = array.size(zones)
    if n0 > 0
        for i = 0 to n0 - 1
            CmiZone cz = array.get(zones, i)
            if cz.state != CmiState.EXPIRED and cz.leftTime < interestStartTime
                cz.state := CmiState.EXPIRED

    // --- 2+3. Tick validation sur chaque pending (iteration descendante pour retrait sur place) :
    //          invalidation = cassure d'extreme → retrait ; sinon decrement, et si barsLeft == 0
    //          → construction + push zone + retrait du pending. ---
    if array.size(pending) > 0
        for i = array.size(pending) - 1 to 0
            PendingCMI p = array.get(pending, i)
            bool invalidated = false
            if p.side == CmiSide.BULL and close < p.low
                invalidated := true
            if p.side == CmiSide.BEAR and close > p.high
                invalidated := true
            if invalidated
                array.remove(pending, i)
            else
                p.barsLeft -= 1
                if p.barsLeft == 0
                    CmiZone newCz = constructZoneFromPending(p, lookbackBars, tfMinutes)
                    if not na(newCz)
                        array.push(zones, newCz)
                    array.remove(pending, i)

    // --- 4. Demarrage d'une nouvelle validation si CMI cette barre. AUCUNE annulation des
    //        pendings existants (validations paralleles). ---
    bool cmiNow = cmiSignal == signal.SignalKind.CMI_BULL or cmiSignal == signal.SignalKind.CMI_BEAR
    if cmiNow
        CmiSide    newSide = cmiSignal == signal.SignalKind.CMI_BULL ? CmiSide.BULL : CmiSide.BEAR
        PendingCMI newP    = PendingCMI.new(bar_index, 3, newSide, open, low, high)
        array.push(pending, newP)

    // --- 5. Cleanup ---
    removeExpiredCmi(zones)
    trimOldestCmi(zones, maxZones)
    zones

// ============================================================
// Anti-chevauchement intra-TF
// ============================================================

// @function Resoud les chevauchements intra-TF dans `zones`. Forward iteration ; chaque CmiZone
//           non-expiree est evaluee contre les precedentes encore non-expirees.
//           Une nouvelle est bloquee si :
//             - son `cmiOpen` tombe dans `[bottom, top]` d'une autre, **OU**
//             - les zones reconstruites se chevauchent geometriquement.
//           `Pending` : la nouvelle passe en PENDING (non dessinee) ; reactivation FIFO quand le
//           bloqueur expire. `Replacement` : tous les bloqueurs non-expires deviennent EXPIRED,
//           la nouvelle devient ACTIVE.
//           Idempotent.
// @param zones        array<CmiZone> a muter in place.
// @param pendingMode  true → Pending, false → Replacement.
// @returns array<CmiZone> (l'array d'entree).
export intraOverlapPass(array<CmiZone> zones, bool pendingMode) =>
    n = array.size(zones)
    if n > 0
        for i = 0 to n - 1
            CmiZone cz = array.get(zones, i)
            if cz.state != CmiState.EXPIRED
                bool hasBlocker = false
                if i > 0
                    for j = 0 to i - 1
                        CmiZone other = array.get(zones, j)
                        if other.state != CmiState.EXPIRED
                            bool openIn = cz.cmiOpen >= other.bottom and cz.cmiOpen <= other.top
                            bool ovlp   = overlap(other, cz)
                            if openIn or ovlp
                                if pendingMode
                                    hasBlocker := true
                                    break
                                other.state := CmiState.EXPIRED
                cz.state := hasBlocker ? CmiState.PENDING : CmiState.ACTIVE
    zones

// @function Downgrade en PENDING toute CmiZone ACTIVE de `lower` qui chevauche geometriquement
//           une zone non-expiree de `higher` (TF superieur). Cross-TF n'utilise PAS le critere
//           open-in-zone (contextes de TF differents) — uniquement chevauchement geometrique.
//           Reactivation auto par le tour suivant d'`intraOverlapPass` quand le bloqueur disparait.
//           Idempotent.
// @param lower   array<CmiZone> du TF inferieur (mute in place).
// @param higher  array<CmiZone> du TF superieur (lecture seule).
// @returns array<CmiZone> (`lower`).
export crossTfOverlapPass(array<CmiZone> lower, array<CmiZone> higher) =>
    nLow = array.size(lower)
    nHi  = array.size(higher)
    if nLow > 0 and nHi > 0
        for i = 0 to nLow - 1
            CmiZone cz = array.get(lower, i)
            if cz.state == CmiState.ACTIVE
                bool blocked = false
                for j = 0 to nHi - 1
                    CmiZone other = array.get(higher, j)
                    if other.state != CmiState.EXPIRED and overlap(other, cz)
                        blocked := true
                        break
                if blocked
                    cz.state := CmiState.PENDING
    lower

// ============================================================
// Periodes d'interet par TF (calcul en chartTz)
// ============================================================

// @function Calcule les bornes `interestStartTime` (ms UTC) des 6 TFs + une 7e pour les UT < M15,
//           selon la TZ du chart fournie (Pine n'expose pas la TZ d'affichage). A appeler dans
//           l'INDICATEUR (contexte chart) ; chaque borne alimente le `updateOne(..., interestStartTime, ...)`.
//             m       : 0 (illimite)
//             w       : 1er janvier de (annee chartTz - 3)
//             d       : 1er du mois (mois chartTz - 6, rollover si <= 0)
//             h4      : 1er du mois (mois chartTz - 1, rollover si <= 0)
//             h1      : minuit du lundi d'il y a 2 semaines (chartTz)
//             m15     : minuit du lundi de la semaine derniere (chartTz)
//             subM15  : PREMIERE bougie de la journee J-1 (chart TZ) — tracee via `var` sur le
//                       day-change. Reel (pas minuit), donc ouverture de seance pour un cash,
//                       ~minuit pour du 24h. Utilise par les TF < M15 en mode test single-TF.
// @param chartTz TZ IANA du chart (ex : "Europe/Paris").
// @returns [mStart, wStart, dStart, h4Start, h1Start, m15Start, subM15Start] (ms UTC).
export computeInterestStarts(simple string chartTz) =>
    int yC   = year(time, chartTz)
    int moC  = month(time, chartTz)
    int domC = dayofmonth(time, chartTz)
    int dowC = dayofweek(time, chartTz)

    int msPerDay      = 86400000
    int todayMidnight = timestamp(chartTz, yC, moC, domC, 0, 0)

    int mStart = 0
    int wStart = timestamp(chartTz, yC - 3, 1, 1, 0, 0)

    int dYearOff = moC - 7 < 0 ? -1 : 0
    int dYear    = yC + dYearOff
    int dMonth   = moC - 6 <= 0 ? moC - 6 + 12 : moC - 6
    int dStart   = timestamp(chartTz, dYear, dMonth, 1, 0, 0)

    int h4YearOff = moC - 2 < 0 ? -1 : 0
    int h4Year    = yC + h4YearOff
    int h4Month   = moC - 1 <= 0 ? moC - 1 + 12 : moC - 1
    int h4Start   = timestamp(chartTz, h4Year, h4Month, 1, 0, 0)

    int daysFromMonday = dowC == dayofweek.sunday ? 6 : dowC - 2
    int mondayThisWeek = todayMidnight - daysFromMonday * msPerDay
    int h1Start        = mondayThisWeek - 14 * msPerDay
    int m15Start       = mondayThisWeek - 7  * msPerDay   // lundi de la semaine derniere

    // < M15 : 1re bougie de J-1 (chart TZ) — capture sur day-change en glissant
    // `todayFirstBar` → `yesterdayFirstBar` a chaque nouveau jour chart.
    var int yesterdayFirstBar = na
    var int todayFirstBar     = na
    if ta.change(dayofmonth(time, chartTz)) != 0
        yesterdayFirstBar := todayFirstBar
        todayFirstBar     := time
    int subM15Start = yesterdayFirstBar

    [mStart, wStart, dStart, h4Start, h1Start, m15Start, subM15Start]

// @function Borne d'obsolescence (ms UTC) pour UN timeframe donne. Mappe `tfMinutes` a la fenetre
//           correspondante de `computeInterestStarts`. Inclut `< M15` (mode test single-TF) :
//           depuis la 1re bougie de J-1.
// @param tfMinutes  Timeframe en minutes (ex : `timeframe.in_seconds() / 60`).
// @param chartTz    TZ IANA du chart.
// @returns Timestamp ms : debut de la periode d'interet pour ce TF (0 = illimite, pour Monthly).
export interestStartForTf(int tfMinutes, simple string chartTz) =>
    [mStart, wStart, dStart, h4Start, h1Start, m15Start, subM15Start] = computeInterestStarts(chartTz)
    tfMinutes >= 43200 ? mStart :
      tfMinutes >= 10080 ? wStart :
      tfMinutes >= 1440  ? dStart :
      tfMinutes >= 240   ? h4Start :
      tfMinutes >= 60    ? h1Start :
      tfMinutes >= 15    ? m15Start : subM15Start

// NB : l'orchestration MTF (6 `request.security` + passes intra/cross-TF) est volontairement
// ABSENTE de cette lib — elle vit dans l'indicateur `zones-MTF.pine`. Raison : Pine interdit qu'un
// `request.security` dans une fonction EXPORTEE depende des arguments de cette fonction (CE10051),
// or l'orchestrateur doit passer `lookbackBars`/`interestStart`/`maxZones` (des args) aux
// `updateOne` appeles dans les `request.security`. Le wiring se fait donc cote indicateur.
